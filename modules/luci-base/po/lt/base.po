msgstr ""
"Nustatyti į pirmąjį valdomąjį, kad būtų įtrauktas į ryšį/obligaciją (sekti, "
"2)"

msgid "Set up DHCP Server"
msgstr "Nustatyti „DHCP“ serverį"

