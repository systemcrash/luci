"<a style=\"color:#37c;font-weight:bold;\" href=\"https://github.com/openwrt/"
"packages/blob/master/net/banip/files/README.md\" target=\"_blank\" "
"rel=\"noreferrer noopener\" >Online-Dokumentation</a>"

