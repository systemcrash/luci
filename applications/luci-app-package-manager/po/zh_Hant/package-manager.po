msgid "%s Configuration"
msgstr "%s 設定"

msgid "%s used (%1024mB used of %1024mB, %1024mB free)"
msgstr "%s 已使用 （%1024mB已使用，總共 %1024mB，剩餘%1024mB）"

msgid ""
"<strong>Warning!</strong> Package operations can <a %s>break your system</a>."
msgstr "<strong>警告！ </strong>套件操作可能<a %s>破壞您的系統</a>。"

msgid "Actions"
msgstr "動作"

msgid "Allow overwriting conflicting package files"
msgstr "允許覆蓋衝突的包檔"

msgid "Automatically remove unused dependencies"
msgstr "自動移除不再使用的依賴項目"

msgid "Available"
msgstr "可用的"

msgid ""
"Below is a listing of the various configuration files used by <em>apk</em>. "
"The configuration in the other files may be changed but is usually not "
"preserved by <em>sysupgrade</em>."
msgstr ""
"下面列出了 <em>apk</em> 使用的各種設定檔。其他設定檔的變更可能在 <em>系統升級"
"</em> 時不會被保留。"

msgid ""
"Below is a listing of the various configuration files used by <em>opkg</em>. "
"Use <em>opkg.conf</em> for global settings and <em>customfeeds.conf</em> for "
"custom repository entries. The configuration in the other files may be "
"changed but is usually not preserved by <em>sysupgrade</em>."
msgstr ""
"下面列出了 <em>opkg</em> 使用的各種設定檔。<em>opkg.conf</em> 用於全域設定，"
"<em>customfeeds.conf</em> 則用於自訂儲存庫項目。其他設定檔的變更可能在 <em>系"
"統升級</em> 時不會被保留。"

msgid "Cancel"
msgstr "取消"

msgid "Clear"
msgstr "清除"

msgid "Configure %s"
msgstr "設定 %s"

msgid "Dependencies"
msgstr "依賴項目"

msgid "Description"
msgstr "描述"

msgid "Details for package <em>%h</em>"
msgstr "套件 <em>%h</em> 的詳細資訊"

msgid "Disk space"
msgstr "磁碟空間"

msgid "Dismiss"
msgstr "關閉"

msgid "Display LuCI translation packages"
msgstr "顯示 LuCI 翻譯包"

msgid "Display all available translation packages"
msgstr "顯示所有可用的翻譯包"

msgid ""
"Display base translation packages and translation packages for already "
"installed languages only"
msgstr "僅顯示已安裝語言的基本翻譯包和翻譯包"

msgid "Displaying %d-%d of %d"
msgstr "正在顯示第 %d 到 %d 筆，共 %d 筆"

msgid "Download and install package"
msgstr "下載並安裝套件包"

msgid "Errors"
msgstr "錯誤"

msgid "Executing package manager"
msgstr "正在執行套件包管理員"

msgid "Filter"
msgstr "過濾"

msgid "Grant access to package management"
msgstr "授予存取軟體套件管理器的權限"

msgid "Hide all translation packages"
msgstr "隱藏所有翻譯包"

msgid "Install"
msgstr "安裝"

msgid "Install additional software and upgrade existing packages with %s."
msgstr "使用 %s 安裝額外軟體或升級現有軟體包。"

msgid "Install suggested translation packages as well"
msgstr "同時安裝建議的翻譯包"

msgid "Installed"
msgstr "已安裝"

msgid ""
"Installing packages from untrusted sources is a potential security risk! "
"Really attempt to install <em>%h</em>?"
msgstr "從不明來源安裝套件很危險! 確定要安裝 <em>%h</em> ?"

msgid "Install…"
msgstr "安裝…"

msgid "Loading configuration data…"
msgstr "載入設定資料中…"

msgid "Loading package information…"
msgstr "載入套件資訊中…"

msgid "MD5"
msgstr "MD5"

msgid "Manually install package"
msgstr "手動安裝套件包"

msgid "Needs upgrade"
msgstr "需要升級"

msgid "Next page"
msgstr "下一頁"

msgid "No information available"
msgstr "無可用資訊"

msgid "No packages"
msgstr "無套件包"

msgid "No packages matching \"<strong>%h</strong>\"."
msgstr "沒有與 \"<strong>%h</strong>\" 相符的軟體包。"

msgid "Not available"
msgstr "無法使用"

msgid "Not installed"
msgstr "未安裝"

msgid "OK"
msgstr "確定"

msgid "Package name"
msgstr "套件包名稱"

msgid "Package name or URL…"
msgstr "套件包名稱或網址…"

msgid "Previous page"
msgstr "上一頁"

msgid "Really attempt to install <em>%h</em>?"
msgstr "確定安裝 <em>%h</em> ?"

msgid "Remove"
msgstr "移除"

msgid "Remove package <em>%h</em>"
msgstr "移除套件 <em>%h</em>"

msgid "Remove…"
msgstr "移除…"

msgid "Require approx. %1024mB size for %d package(s) to install."
msgstr "約需 %1024mB 的空間來安裝 %d 個套件包。"

msgid "Require version %h %h, installed %h"
msgstr "需要版本 %h %h，現已安裝 %h"

msgid ""
"Required dependency package <em>%h</em> is not available in any repository."
msgstr "依賴的套件 <em>%h</em> 不存在於任何的儲存庫。"

msgid "Requires update to %h %h"
msgstr "需要更新至 %h %h"

msgid "Reset"
msgstr "重置"

msgid "SHA256"
msgstr "SHA-256"

msgid "Save"
msgstr "儲存"

msgid "Saving configuration data…"
msgstr "正在儲存設定值…"

msgid "Size"
msgstr "大小"

msgid "Size (%s)"
msgstr "大小 (.ipk)"

msgid "Software"
msgstr "軟體"

msgid "Suggested translations"
msgstr "建議的翻譯"

msgid "Suggested translations require approx. %1024mB additional space."
msgstr "建議的翻譯需要大約 %1024mB 的額外空間。"

msgid "The <em>%s %h</em> command failed with code <code>%d</code>."
msgstr "<em>%s %h</em> 指令失敗，代碼為 <code>%d</code>。"

msgid ""
"The installed version of package <em>%h</em> is not compatible, require %s "
"while %s is installed."
msgstr "已安裝的套件 <em>%h</em> 版本不相容，要求 %s 而 %s 已安裝。"

msgid "The package <em>%h</em> is not available in any configured repository."
msgstr "套件 <em>%h</em> 在所有已設定的儲存庫中不可用。"

msgid ""
"The repository version of package <em>%h</em> is not compatible, require %s "
"but only %s is available."
msgstr "套件包 <em>%h</em> 在儲存庫中的版本不相容，要求 %s 但僅有 %s 可用。"

msgid "Type to filter…"
msgstr "輸入以進行過濾…"

msgid "Unable to execute <em>%s %s</em> command: %s"
msgstr "無法執行<em>%s %s</em>指令：%s"

msgid "Unable to read %s: %s"
msgstr "無法讀取 %s: %s"

msgid "Unable to save %s: %s"
msgstr "無法儲存 %s: %s"

msgid "Update lists…"
msgstr "更新清單…"

msgid "Updates"
msgstr "可升級"

msgid "Upgrade…"
msgstr "升級…"

msgid "Upload Package…"
msgstr "上傳套件包…"

msgid "Version"
msgstr "版本"

msgid "Version incompatible"
msgstr "版本不相容"

msgid "Waiting for the <em>%s %h</em> command to complete…"
msgstr "正在等待 <em>%s %h</em> 指令完成…"

