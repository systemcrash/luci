msgid ""
"A file list/WebDAV program that supports multiple storages, powered by Gin "
"and Solidjs."
msgstr "一個支援多儲存的 檔案列表/WebDAV 程式，使用 Gin 和 Solidjs。"

msgid "AList"
msgstr "AList"

msgid ""
"Allow connection even if the remote TLS certificate is invalid (<strong>not "
"recommended</strong>)."
msgstr "即使遠端 TLS 憑證無效，也允許連線 (<strong>不推薦</strong>)。"

msgid "Allow insecure connection"
msgstr "允許不安全連線"

msgid "Collecting data..."
msgstr "正在收集資料中..."

msgid "Default webUI/WebDAV login username is %s and password is %s."
msgstr "預設 webUI/WebDAV 登錄使用者名稱 %s 及密碼 %s。"

msgid "Enable"
msgstr "啟用"

msgid "Enable logging"
msgstr "啟用日誌"

msgid "Expecting: %s"
msgstr "請輸入：%s"

msgid "Grant UCI access for luci-app-alist"
msgstr "授予 luci-app-alist 存取 UCI 設定的權限"

msgid "Listen address"
msgstr "監聽位址"

msgid "Listen port"
msgstr "監聽連接埠"

msgid "Loading..."
msgstr "載入中..."

msgid "Log"
msgstr "日誌"

msgid "Log file does not exist."
msgstr "日誌檔案不存在。"

msgid "Log is empty."
msgstr "日誌為空。"

msgid "Login expiration time"
msgstr "登錄過期時間"

msgid "Max connections"
msgstr "最大連線數"

msgid "Max log age"
msgstr "日誌最長保留時間"

msgid "Max log backups"
msgstr "日誌最大備份數"

msgid "Max log size"
msgstr "日誌最大大小"

msgid "NOT RUNNING"
msgstr "未執行"

msgid "Open Web Interface"
msgstr "開啟 Web 介面"

msgid "RUNNING"
msgstr "執行中"

msgid "Refresh every %s seconds."
msgstr "每 %s 秒更新。"

msgid "Settings"
msgstr "設定"

msgid "The maximum days of the log file to retain."
msgstr "日誌檔案的最長儲存天數。"

msgid ""
"The maximum number of concurrent connections at the same time (0 = "
"unlimited)."
msgstr "允許的最大並行連線數 (0 = 不限制)。"

msgid "The maximum number of old log files to retain."
msgstr "要保留的最大舊日誌檔案數量。"

msgid "The maximum size in megabytes of the log file before it gets rotated."
msgstr "輪換前的最大日誌大小 (單位：MB)。"

msgid "Unknown error: %s"
msgstr "未知錯誤：%s"

msgid "User login expiration time (in hours)."
msgstr "使用者登錄過期時間 (單位：小時)。"

msgid "valid IP address"
msgstr "有效 IP 位址"
