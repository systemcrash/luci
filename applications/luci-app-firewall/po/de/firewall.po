msgstr "Kommentar"

msgid "Conntrack Settings"
msgstr "Conntrack-Einstellungen"

msgid "Conntrack helpers"
msgstr "Conntrack-Helfer"

msgid "Contents have been saved."
msgstr "Inhalte wurden gespeichert."

msgid "Continue"
msgstr "Fortfahren"

msgid "Counters"
msgstr "Zähler"

