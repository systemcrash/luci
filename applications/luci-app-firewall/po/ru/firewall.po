msgid ""
"From %{src}%{src_ip?, IP %{src_ip#%{next?, }<var%{item.inv? data-"
"tooltip=\"Match IP addresses except %{item.val}.\"}>%{item.ival}</"
"var>}}%{src_port?, port %{src_port#%{next?, }<var%{item.inv? data-"
