"From %{src}%{src_device?, interface <var>%{src_device}</var>}%{src_ip?, IP "
"%{src_ip#%{next?, }<var%{item.inv? data-tooltip=\"Match IP addresses except "
"%{item.val}.\"}>%{item.ival}</var>}}%{src_port?, port %{src_port#%{next?, }"
