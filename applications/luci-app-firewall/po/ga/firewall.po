msgstr ""
"<var data-tooltip=\"MASQUERADE\">Athscríobh go huathoibríoch</var> IP foinse"

msgid ""
"<var data-tooltip=\"NOTRACK\">Do not track</var> %{src?%{dest?forward:input}:"
