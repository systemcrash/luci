msgstr "Commento"

msgid "Conntrack Settings"
msgstr "Impostazioni di conntrack"

msgid "Conntrack helpers"
msgstr "Assistenti di conntrack"

msgid "Contents have been saved."
msgstr "I contenuti sono stati salvati."

