msgid "Absolute maximum range for position decoding"
msgstr "位置解码的绝对最大范围"

msgid "Accuracy of receiver location in json metadata"
msgstr "json元数据中接收方位置的准确性"

msgid "Allow forwarding of received mlat results to output ports"
msgstr "允许转发接收到的 MLAT 结果到输出端口"

msgid "Apply a 1Hz DC filter to input data"
msgstr "将 1Hz DC 过滤器应用到输入数据"

msgid "Approximate"
msgstr "预估"

msgid "Base directory for the internal HTTP server"
msgstr "内部 HTTP 服务器的根目录"

msgid "Collect/show range histogram"
msgstr "收集/显示范围直方图"

msgid "Data file"
msgstr "数据文件"

msgid "Debug mode flags"
msgstr "调试模式标识"

msgid "Default"
msgstr "默认"

msgid "Disable messages with broken CRC"
msgstr "禁止CRC校验错误的消息"

msgid "Disable single-bits error correction using CRC"
msgstr "禁止使用单BIT矫正CRC错误"

msgid "Display raw messages in Beast ascii mode"
msgstr "在野兽ASCII模式下显示原始消息"

msgid "Do not apply CRC corrections to messages we forward"
msgstr "不要对转发的消息应用 CRC 更正"

msgid "Enable automatic gain control"
msgstr "启用自动增益控制"

msgid "Enable decoding of SSR Modes 3/A & 3/C"
msgstr "启动SSR模式3/A和3/C解码"

msgid "Enable just networking, no RTL device or file used"
msgstr "仅启用网络功能，不使用 RTL 设备或文件"

msgid "Enable networking"
msgstr "启用网络功能"

msgid "Enable phase enhancement"
msgstr "启用相位增强"

msgid "Enable single-bits error correction using CRC"
msgstr "利用CRC进行单比特纠错"

msgid "Enabled"
msgstr "已启用"

msgid "Exact"
msgstr "提取"

msgid "FlightAware TSV output port"
msgstr "FlightAware TSV 输出端口"

msgid "Frequency"
msgstr "频率"

msgid "Gain (-10 for auto-gain)"
msgstr "增益（输入 -10 使用自动增益）"

msgid "Grant UCI access for luci-app-dump1090"
msgstr "授予UCI访问luci-app-dump1090的权限"

msgid "HTTP server port"
msgstr "HTTP 服务器端口"

msgid "IP address to bind to"
msgstr "绑定IP"

msgid "Measure noise power"
msgstr "测量噪声水平"

msgid "More CPU for more messages"
msgstr "消息越多消耗 CPU 越多"

msgid "No location"
msgstr "无位置"

msgid "Periodically write json output to a directory"
msgstr "定期向目录写入JSON输出"

msgid "Print stats at exit"
msgstr "退出时显示统计信息"

msgid "RTL device index"
msgstr "RTL 设备索引"

msgid "Reference/receiver latitude for surface posn"
msgstr "表面POSS的参考/接收纬度"

msgid "Reference/receiver longitude for surface posn"
msgstr "表面POSS的参考/接收经度"

msgid "Respawn"
msgstr "刷新"

msgid "Sample format for data file"
msgstr "数据文件的样本格式"

msgid "Set receiver error in parts per million"
msgstr "设置接收机百万分之一的误差"

msgid "Show and reset stats every seconds"
msgstr "每秒显示并重置统计信息"

msgid "Show only ICAO addresses"
msgstr "仅显示 ICAO 地址"

msgid "Show only messages hex values"
msgstr "仅显示消息的十六进制值"

msgid "Strip IQ file removing samples"
msgstr "剔除 IQ 文件移除样本"

msgid "TCP BaseStation output listen port"
msgstr "TCP基站 输出侦听端口"

msgid "TCP Beast input listen port"
msgstr "TCP 输入监听端口"

msgid "TCP Beast output listen port"
msgstr "TCP 输出监听端口"

msgid "TCP buffer size 64Kb * (2^n)"
msgstr "TCP 缓冲区大小 64Kb * (2^n)"

msgid "TCP heartbeat rate in seconds"
msgstr "每秒钟的TCP心跳包速率"

msgid "TCP raw input listen port"
msgstr "TCP原始输入侦听端口"

msgid "TCP raw output in Beast binary format"
msgstr "Beast 二进制文件格式的TCP 原始输出"

msgid "TCP raw output listen port"
msgstr "TCP原始输出侦听端口"

msgid "TCP raw output memory flush rate in seconds"
msgstr "TCP 原始输出内存刷新率 (秒)"

msgid "TCP raw output minimum size"
msgstr "TCP原始输出的最小大小"

msgid "Use metric units"
msgstr "使用公制单位"

msgid "Use the 2.4MHz demodulator"
msgstr "使用 2.4 MHz 解调制器"

msgid "When reading from a file play back in realtime, not at max speed"
msgstr "当读取文件时，实时播放，而不是以最高速度播放"

msgid "Write json output every t seconds"
msgstr "每 t 秒写一次 JSON 输出"

msgid "dump1090"
msgstr "dump1090"

msgid ""
"dump1090 is a Mode S decoder specifically designed for RTLSDR devices. Here "
"you can configure the settings."
msgstr "dump1090是专为RTLSDR设备设计的Mode S解码器，你可以在此处配置设置。"
