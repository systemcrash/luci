msgid "Bridge"
msgstr "Bridge"

msgid "Channel Sets"
msgstr "Bộ kênh"

msgid "Data Channels"
msgstr "Kênh dữ liệu"

msgid "Define data channels over which outbound filtered packets will flow."
msgstr "Xác định các kênh dữ liệu mà các gói được lọc ra ngoài sẽ bị ra ngoài."

msgid ""
"Define filter rules to apply to outbound packets. Matching packets will flow "
"over the data channel."
msgstr ""
"Xác định các quy tắc lọc để áp dụng cho các gói gửi đi. Các gói phù hợp sẽ "
"chảy qua kênh dữ liệu."

msgid "Define primary channels and their corresponding data channels."
msgstr "Xác định các kênh chính và các kênh dữ liệu tương ứng của chúng."

msgid "Destination port"
msgstr "Cổng đích"

msgid "Dual Channel Wi-Fi AP Daemon"
msgstr "Dual Channel Wi-Fi AP Daemon"

msgid "Dual Channel WiFi"
msgstr "Dual Channel WiFi"

msgid "Enable"
msgstr "Bật lên"

msgid "Filter Sets"
msgstr "Bộ lọc"

msgid "Filters"
msgstr "Bộ lọc"

msgid "General"
msgstr "Tổng quát"

msgid "General Settings"
msgstr "Các cài đặt chung"

msgid "Grant UCI access for luci-app-dcwapd"
msgstr "Cấp quyền truy cập UCI cho luci-app-dcwapd"

msgid "Interfaces"
msgstr "Giao diện"

msgid "MAC Address"
msgstr "Địa chỉ MAC"

msgid "Packet size"
msgstr "Kích thước packet"

msgid "Protocol"
msgstr "Giao thức"

msgid "SSID"
msgstr "SSID"

msgid "Select filters to apply to matching MAC addresses."
msgstr "Chọn bộ lọc để áp dụng cho các địa chỉ MAC phù hợp."

msgid "Source IP"
msgstr "IP nguồn"

msgid "Source port"
msgstr "Source port"

msgid "Specify the temporary directory for dcwapd file storage."
msgstr "Chỉ định thư mục tạm thời để lưu trữ tệp dcwapd."

msgid "Temp Directory"
msgstr "Thư mục tạm"

msgid ""
"With %s you can use two simultaneous Wi-Fi connections to decrease wireless "
"traffic congestion and increase throughput."
msgstr ""

