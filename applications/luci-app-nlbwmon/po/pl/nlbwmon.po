msgstr "Pobieranie/Aplikacja"

msgid "Download Database Backup"
msgstr "Pobierz kopię zapasową bazy danych"

msgid "Dualstack enabled hosts"
msgstr "Hosty z włączoną funkcją dualstack"

msgid "Due date"
msgstr "Termin ważności"

msgid "Dump (JSON)"
msgstr "Zrzuć (JSON)"

