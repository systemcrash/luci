msgstr "Pogrupowane według IP (CSV)"

msgid "Grouped by MAC (CSV)"
msgstr "Pogrupowane według MAC (CSV)"

msgid "Grouped by protocol (CSV)"
msgstr "Pogrupowane według protokołu (CSV)"

