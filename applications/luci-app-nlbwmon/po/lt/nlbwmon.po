msgid "%d IPv4-only hosts"
msgstr "„%d“ Tik-IPv4 skleidėjų/vedėjų"

msgid "%d IPv6-only hosts"
msgstr "„%d“ Tik-IPv6 skleidėjų/vedėjų"

msgid "%d dual-stack hosts"
msgstr "„%d“ dvisluoksniai skleidėjai/vedėjai"

msgid "%s and %s"
msgstr "„%s“ ir „%s“"

msgid "%s, %s and %s"
msgstr "„%s“, „%s“ ir „%s“"

msgid "-1 - Restart every last day of month"
msgstr ""
"-1 – Paleisti iš naujo kiekvieną kartą, kai būna paskutinė mėnesio diena"

msgid "-7 - Restart a week before end of month"
msgstr "-7 – Paleisti iš naujo kas savaitę, prieš mėnesio pabaigą"

msgid "1 - Restart every 1st of month"
msgstr "1 – Paleisti iš naujo kiekvieną 1-ąją mėnesio dieną"

msgid "10m - frequent commits at the expense of flash wear"
msgstr ""
"10min. – dažni pateikimai, spartesnis išliekamosios atminties (vietovės) "
"nusidėvėjimas"

msgid "12h - compromise between risk of data loss and flash wear"
msgstr ""
"12val. – kompromisas tarp duomenų praradimo rizikos ir išliekamosios "
"atminties (vietovės) nusidėvėjimo"

msgid "24h - least flash wear at the expense of data loss risk"
msgstr ""
"24val. – mažiausias išliekamosios atminties (vietovės) nusidėvėjimas, tačiau "
"didesnė duomenų praradimo rizika"

msgid "30s - refresh twice per minute for reasonably current stats"
msgstr ""
"30-imt sekundžių – atnaujinti du kartus per minutę, kad gautumėte "
"„pakankamai aktualią“ statistiką"

msgid "5m - rarely refresh to avoid frequently clearing conntrack counters"
msgstr ""
"5-ios minutės – retai atnaujinti, kad nereikėtų dažnai išvalyti – "
"„conntrack“ skaitiklių"

msgid "60s - commit minutely, useful for non-flash storage"
msgstr ""
"60-imt sekundžių – nusiųsti/patvirtinti kas minute, naudinga ne "
"išliekamosios atminties saugojimui"

msgid "<big id=\"conn-total\">0</big> connections"
msgstr "<big id=\"conn-total\">0</big> prisijungimų"

msgid "<big id=\"host-total\">0</big> hosts"
msgstr "<big id=\"host-total\">0</big> skleidėjų/vedėjų"

msgid "<big id=\"ipv6-hosts\">0%</big> IPv6 support rate among hosts"
msgstr ""
"<big id=\"ipv6-hosts\">0%</big> IPv6 palaikymo lygis tarp skleidėjų/vedėjų"

msgid "<big id=\"ipv6-rx\">0B</big> total IPv6 download"
msgstr "<big id=\"ipv6-rx\">0B</big> iš viso atsisiųsta per IPv6"

msgid "<big id=\"ipv6-share\">0%</big> of the total traffic is IPv6"
msgstr "<big id=\"ipv6-share\">0%</big> iš bendro srauto yra IPv6"

msgid "<big id=\"ipv6-tx\">0B</big> total IPv6 upload"
msgstr "<big id=\"ipv6-tx\">0B</big> iš viso nusiųsta/įkelta per IPv6"

msgid "<big id=\"layer7-most-conn\">0</big> cause the most connections"
msgstr "<big id=\"layer7-most-conn\">0</big> sukelia daugiausiai prisijungimų"

msgid "<big id=\"layer7-most-rx\">0</big> cause the most download"
msgstr "<big id=\"layer7-most-rx\">0</big> sukelia daugiausiai atsisiuntimų"

msgid "<big id=\"layer7-most-tx\">0</big> cause the most upload"
msgstr "<big id=\"layer7-most-tx\">0</big> sukelia daugiausiai nusiuntimų"

msgid "<big id=\"layer7-total\">0</big> different application protocols"
msgstr ""
"<big id=\"layer7-total\">0</big> skirtingi pritaikymo (programų/aplikacijų) "
"protokolai"

msgid "<big id=\"rx-total\">0</big> download"
msgstr "<big id=\"rx-total\">0</big> atsisiųsti"

msgid "<big id=\"tx-total\">0</big> upload"
msgstr "<big id=\"tx-total\">0</big> įkelti"

msgid "Accounting period"
msgstr "Apskaitos periodas"

msgid "Advanced Settings"
msgstr "Pažangūs nustatymai"

msgid "Application"
msgstr "Aplikacija"

msgid "Application Protocols"
msgstr "Aplikacijos protokolai"

msgid "Backup"
msgstr "Atkūrimas/Sukurti atsarginę kopiją"

msgid "Bandwidth Monitor"
msgstr "Duomenų siuntimo ir perdavimo srauto pralaidumo prižiūryklė/-ėtojas"

msgid ""
"Changing the accounting interval type will invalidate existing databases!"
"<br /><strong><a href=\"%s\">Download backup</a></strong>."
msgstr ""
"Pakeitus apskaitos intervalo tipą, esamos duomenų bazės taps negaliojančios!"
"<br /><strong><a href=\"%s\">Atsisiųsti atsarginę kopiją</a></strong>."

msgid ""
"Choose \"Day of month\" to restart the accounting period monthly on a "
"specific date, e.g. every 3rd. Choose \"Fixed interval\" to restart the "
"accounting period exactly every N days, beginning at a given date."
msgstr ""
"Pasirinkite – „Mėnesio diena“, jei norite kas mėnesį iš naujo pradėti "
"apskaitinį laikotarpį, per tam tikrą datą, pvz.: kas 3-čia/-čias. "
"Pasirinkite – „Įtvirtintas intervalas“, jei norite iš naujo pradėti "
"apskaitos periodą, tiksliai kas – N dienų, pradedant nuo savitosios datos."

msgid "Collecting data..."
msgstr "Renkama/-i informacija (duomenys)..."

msgid "Commit interval"
msgstr "Nusiuntimo/Patvirtinimo intervalas"

msgid "Compress database"
msgstr "Suglaudinti duomenų bazę"

msgid "Configuration"
msgstr "Konfigūravimas"

msgid "Conn."
msgstr "Pris."

msgid "Connections"
msgstr "Prisijungimai"

msgid "Connections / Host"
msgstr "Prisijungimai┃Skleidėjas/Vedėjas"

msgid "Database directory"
msgstr "Duomenų bazės katalogas"

msgid ""
"Database storage directory. One file per accounting period will be placed "
"into this directory."
msgstr ""
"Duomenų bazės vietovės katalogas. Vienas failas per apskaitos periodą bus "
"įtrauktas į šį katalogą."

msgid "Day of month"
msgstr "Mėnesio diena"

msgid ""
"Day of month to restart the accounting period. Use negative values to count "
"towards the end of month, e.g. \"-5\" to specify the 27th of July or the "
"24th of February."
msgstr ""
"Mėnesio diena, nuo kurios pradedamas apskaitos periodas. Naudokite neigiamas "
"reikšmes, jei norite skaičiuoti iki mėnesio pabaigos, pvz.: „-5-i“, jei "
"norite nurodyti – liepos 27-ą d. arba vasario 24-ą d."

msgid "Dismiss"
msgstr "Nepaisyti"

msgid "Display"
msgstr "Rodyti"

msgid "Down. (Bytes)"
msgstr "Atsiųsta. (Baitai)"

msgid "Down. (Pkts.)"
msgstr "Atsiųsta. (paketai)"

