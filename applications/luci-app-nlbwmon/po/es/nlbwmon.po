msgstr ""
"<big id=\"ipv6-hosts\">0%</big> tasa de compatibilidad de IPv6 entre hosts"

msgid "<big id=\"ipv6-rx\">0B</big> total IPv6 download"
msgstr "<big id=\"ipv6-rx\">0B</big> descarga total de IPv6"

msgid "<big id=\"ipv6-share\">0%</big> of the total traffic is IPv6"
msgstr "<big id=\"ipv6-share\">0%</big> del tráfico total es IPv6"

msgid "<big id=\"ipv6-tx\">0B</big> total IPv6 upload"
msgstr "<big id=\"ipv6-tx\">0B</big> carga total de IPv6"

msgid "<big id=\"layer7-most-conn\">0</big> cause the most connections"
msgstr "<big id=\"layer7-most-conn\">0</big> causa la mayoría de conexiones"

msgid "<big id=\"layer7-most-rx\">0</big> cause the most download"
msgstr "<big id=\"layer7-most-rx\">0</big> causa la mayor descarga"

