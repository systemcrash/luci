msgstr "<big id=\"tx-total\">0</big> de carga"

msgid "Accounting period"
msgstr "Período de contabilización"

msgid "Advanced Settings"
msgstr "Ajustes avanzados"

msgid "Application"
msgstr "Aplicación"

msgid "Application Protocols"
msgstr "Protocolos de aplicación"

