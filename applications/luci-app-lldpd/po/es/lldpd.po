msgstr "CDP"

msgid "CDP version"
msgstr "Versión CDP"

msgid "CDPv1 and CDPv2"
msgstr "CDPv1 y CDPv2"

msgid "Cannot have both interface %s and its exclusion %s"
msgstr "No se pueden tener tanto la interfaz %s como su exclusión %s"

