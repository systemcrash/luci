msgid "Alert"
msgstr "警报"

msgid "By default, this value is \"\"."
msgstr "此值默认为 \"\"。"

msgid "By default, this value is \"0.0.0.0\"."
msgstr "此值默认为 \"0.0.0.0\"。"

msgid "By default, this value is \"Info\"."
msgstr "此值默认为 \"Info\"。"

msgid "By default, this value is \"tcp\"."
msgstr "此值默认为 \"tcp\"。"

msgid "By default, this value is 7000."
msgstr "此值默认为 7000。"

msgid "Collecting data ..."
msgstr "正在收集数据…"

msgid "Common Settings"
msgstr "常规设置"

msgid "Critical"
msgstr "严重"

msgid "Custom domains"
msgstr "自定义域"

msgid "Debug"
msgstr "调试"

msgid "Disabled xfrpc service"
msgstr "禁用了 xfrpc 服务"

msgid "Emergency"
msgstr "紧急"

msgid "Error"
msgstr "错误"

msgid "General Settings"
msgstr "常规设置"

msgid "Grant access to LuCI app xfrpc"
msgstr "授予访问 LuCI 应用 xfrpc 的权限"

msgid "HTTP Settings"
msgstr "HTTP 设置"

msgid "If remote_port is 0, frps will assign a random port for you"
msgstr "如远程端口为 0，frps 将给你分配一个端口"

msgid "Info"
msgstr "信息"

msgid "Local IP"
msgstr "本地 IP"

msgid "Local port"
msgstr "本地端口"

msgid "LocalIp specifies the IP address or host name to proxy to."
msgstr "LocalIp 指定要经代理访问的 IP 地址或主机名。"

msgid "LocalPort specifies the port to proxy to."
msgstr "LocalPort 指定要经代理访问的端口。"

msgid "Log level"
msgstr "日志级别"

msgid ""
"LogLevel specifies the minimum log level. Valid values are \"Debug\", "
"\"Info\", \"Notice\", \"Warning\", \"Error\", \"Critical\", \"Alert\" and "
"\"Emergency\"."
msgstr ""
"LogLevel 指定最小日志等级。有效值为 \"调试”、“信息“、”注意“、”警告“、错"
"误”、“严重”、“警报”和“紧急”。"

msgid "NOT RUNNING"
msgstr "未在运行"

msgid "Name can not be \"common\""
msgstr "名称不能为\"common\""

msgid "Notice"
msgstr "注意"

msgid "Proxy Settings"
msgstr "代理设置"

msgid "Proxy type"
msgstr "代理类型"

msgid ""
"ProxyType specifies the type of this proxy. Valid values include \"tcp\", "
"\"http\", \"https\"."
msgstr "ProxyType 指定代理类型。有效值包括 \"tcp\"、 \"http\"、 \"https\"."

msgid "RUNNING"
msgstr "运行中"

msgid "Remote port"
msgstr "远程端口"

msgid "Reverse proxy"
msgstr "反向代理"

msgid "Server address"
msgstr "服务器地址"

msgid "Server address specifies the address of the server to connect to."
msgstr "Server address 指定要连接的服务器的地址。"

msgid "Server port"
msgstr "服务器端口"

msgid "Server port specifies the port to connect to the server on."
msgstr "Server port 指定要连接的服务器端口。"

msgid "Startup Settings"
msgstr "启动设置"

msgid "Subdomain"
msgstr "子域名"

msgid "Token"
msgstr "令牌"

msgid ""
"Token specifies the authorization token used to create keys to be sent to "
"the server. The server must have a matching token for authorization to "
"succeed."
msgstr ""
"Token 指定授权令牌，该令牌用于创建要发送到服务器的密钥。服务器必须有相匹配的"
"令牌，授权才能成功。"

msgid "Warning"
msgstr "警告"

msgid "x-frp Client"
msgstr "x-frp 客户端"

msgid "xfrpc"
msgstr "xfrpc"

msgid "xfrpc is a c language frp client for frps."
msgstr "xfrpc 是 frps 的 C 语言 frp 客户端。"
