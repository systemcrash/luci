msgid "Alert"
msgstr "警示"

msgid "By default, this value is \"\"."
msgstr "該值預設為 \"\"."

msgid "By default, this value is \"0.0.0.0\"."
msgstr "該值預設為 \"0.0.0.0\"."

msgid "By default, this value is \"Info\"."
msgstr "該值預設為 \"info\"."

msgid "By default, this value is \"tcp\"."
msgstr "該值預設為 \"tcp\"."

msgid "By default, this value is 7000."
msgstr "該值預設為 7000."

msgid "Collecting data ..."
msgstr "資料採集中..."

msgid "Common Settings"
msgstr "通用設定"

msgid "Critical"
msgstr "致命錯誤"

msgid "Custom domains"
msgstr "自定義網域"

msgid "Debug"
msgstr "除錯"

msgid "Disabled xfrpc service"
msgstr "禁用xfrpc服務"

msgid "Emergency"
msgstr "緊急"

msgid "Error"
msgstr "錯誤"

msgid "General Settings"
msgstr "一般設定"

msgid "Grant access to LuCI app xfrpc"
msgstr "授予對 LuCI 程式 xfrpc 的權限"

msgid "HTTP Settings"
msgstr "HTTP 設定"

msgid "If remote_port is 0, frps will assign a random port for you"
msgstr "如果遠端埠號為0，frps會為你分配一個隨機埠號"

msgid "Info"
msgstr "資訊"

msgid "Local IP"
msgstr "本地IP"

msgid "Local port"
msgstr "本地埠號"

msgid "LocalIp specifies the IP address or host name to proxy to."
msgstr "LocalIp指定要代理的IP位址或主機名。"

msgid "LocalPort specifies the port to proxy to."
msgstr "LocalPort指定要代理的埠號。"

msgid "Log level"
msgstr "紀錄級別"

msgid ""
"LogLevel specifies the minimum log level. Valid values are \"Debug\", "
"\"Info\", \"Notice\", \"Warning\", \"Error\", \"Critical\", \"Alert\" and "
"\"Emergency\"."
msgstr ""
"LogLevel 指定最低日誌級別。有效值為 “除錯”，“資訊”，“注意”，“警告”，“錯"
"誤”，“致命錯誤”，“警示”和“緊急”。"

msgid "NOT RUNNING"
msgstr "未執行"

msgid "Name can not be \"common\""
msgstr "名稱不能為 \"common\""

msgid "Notice"
msgstr "注意"

msgid "Proxy Settings"
msgstr "代理設定"

msgid "Proxy type"
msgstr "代理類別"

msgid ""
"ProxyType specifies the type of this proxy. Valid values include \"tcp\", "
"\"http\", \"https\"."
msgstr "ProxyType 指定代理類別。有效值包括 \"tcp\", \"http\", \"https\"。"

msgid "RUNNING"
msgstr "執行中"

msgid "Remote port"
msgstr "遠端埠號"

msgid "Reverse proxy"
msgstr "反向代理"

msgid "Server address"
msgstr "伺服器位址"

msgid "Server address specifies the address of the server to connect to."
msgstr "Server address指定連接的伺服器位址。"

msgid "Server port"
msgstr "伺服器埠號"

msgid "Server port specifies the port to connect to the server on."
msgstr "Server port指定連接的伺服器埠號。"

msgid "Startup Settings"
msgstr "啟動設定"

msgid "Subdomain"
msgstr "子網域"

msgid "Token"
msgstr "權杖"

msgid ""
"Token specifies the authorization token used to create keys to be sent to "
"the server. The server must have a matching token for authorization to "
"succeed."
msgstr ""
"Token指定授權的權杖，用於建立傳送到伺服器的金鑰。伺服器必須具有匹配的權杖才能"
"成功授權。"

msgid "Warning"
msgstr "警告"

msgid "x-frp Client"
msgstr "x-frp 用戶端"

msgid "xfrpc"
msgstr "xfrpc"

msgid "xfrpc is a c language frp client for frps."
msgstr "xfrpc是C語言的frp用戶端。"
