msgid "Alert"
msgstr "Meldung"

msgid "By default, this value is \"\"."
msgstr "Standardmäßig ist dieser Wert \"\"."

msgid "By default, this value is \"0.0.0.0\"."
msgstr "Standardmäßig ist dieser Wert \"0.0.0.0\"."

msgid "By default, this value is \"Info\"."
msgstr "Standardmäßig ist dieser Wert \"Info\"."

msgid "By default, this value is \"tcp\"."
msgstr "Standardmäßig ist dieser Wert \"tcp\"."

msgid "By default, this value is 7000."
msgstr "Standardmäßig ist dieser Wert 7000."

msgid "Collecting data ..."
msgstr "Sammeln von Daten ..."

msgid "Common Settings"
msgstr "Allgemeine Einstellungen"

msgid "Critical"
msgstr "Kritisch"

msgid "Custom domains"
msgstr "Benutzerdefinierte Domänen"

msgid "Debug"
msgstr "Debug"

msgid "Disabled xfrpc service"
msgstr "Deaktivierter xfrpc-Dienst"

msgid "Emergency"
msgstr "Notfall"

msgid "Error"
msgstr "Fehler"

msgid "General Settings"
msgstr "Allgemeine Einstellungen"

msgid "Grant access to LuCI app xfrpc"
msgstr "Zugriff auf die LuCI-Anwendung xfrpc gewähren"

msgid "HTTP Settings"
msgstr "HTTP-Einstellungen"

msgid "If remote_port is 0, frps will assign a random port for you"
msgstr "Wenn remote_port 0 ist, weist frps Ihnen einen zufälligen Port zu"

msgid "Info"
msgstr "Info"

msgid "Local IP"
msgstr "Lokale IP"

msgid "Local port"
msgstr "Lokaler Port"

msgid "LocalIp specifies the IP address or host name to proxy to."
msgstr "LocalIp gibt die IP-Adresse oder den Hostnamen für den Proxy an."

msgid "LocalPort specifies the port to proxy to."
msgstr "LocalPort spezifiziert den Port des Proxys."

msgid "Log level"
msgstr "Protokollierungslevel"

msgid ""
"LogLevel specifies the minimum log level. Valid values are \"Debug\", "
"\"Info\", \"Notice\", \"Warning\", \"Error\", \"Critical\", \"Alert\" and "
"\"Emergency\"."
msgstr ""
"LogLevel gibt die unterste Protokollebene an. Gültige Werte sind \"Debug\", "
"\"Info\", \"Notice\", \"Warning\", \"Error\", \"Critical\", \"Alert\" und "
"\"Emergency\"."

msgid "NOT RUNNING"
msgstr "LÄUFT NICHT"

msgid "Name can not be \"common\""
msgstr "Name kann nicht \"common\" sein"

msgid "Notice"
msgstr "Hinweis"

msgid "Proxy Settings"
msgstr "Proxy-Einstellungen"

msgid "Proxy type"
msgstr "Proxy-Typ"

msgid ""
"ProxyType specifies the type of this proxy. Valid values include \"tcp\", "
"\"http\", \"https\"."
msgstr ""
"ProxyType gibt die Art dieses Proxys an. Gültige Werte sind z.B. \"tcp\", "
"\"http\", \"https\"."

msgid "RUNNING"
msgstr "LÄUFT"

msgid "Remote port"
msgstr "Entfernter Port"

msgid "Reverse proxy"
msgstr "Reverse Proxy"

msgid "Server address"
msgstr "Server-Adresse"

msgid "Server address specifies the address of the server to connect to."
msgstr ""
"Serveradresse gibt die Adresse des Servers an, mit dem eine Verbindung "
"hergestellt werden soll."

msgid "Server port"
msgstr "Server-Port"

msgid "Server port specifies the port to connect to the server on."
msgstr ""
"Serverport gibt den Port an, über den eine Verbindung zum Server hergestellt "
"werden soll."

msgid "Startup Settings"
msgstr "Startup-Einstellungen"

msgid "Subdomain"
msgstr "Unterdomäne"

msgid "Token"
msgstr "Token"

msgid ""
"Token specifies the authorization token used to create keys to be sent to "
"the server. The server must have a matching token for authorization to "
"succeed."
msgstr ""
"Token gibt den Berechtigungstoken an, der verwendet wird, um Schlüssel zu "
"erstellen, die an den Server gesendet werden sollen. Der Server muss einen "
"passenden Token für die Berechtigung haben, um erfolgreich zu sein."

msgid "Warning"
msgstr "Warnung"

msgid "x-frp Client"
msgstr "x-frp Client"

msgid "xfrpc"
msgstr "xfrpc"

msgid "xfrpc is a c language frp client for frps."
msgstr "xfrpc ist ein c-language frp-Client für frps."
