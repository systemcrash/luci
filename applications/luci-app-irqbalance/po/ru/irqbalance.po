msgid "Cache level at which irqbalance partitions cache domains."
msgstr "Уровень кэша, на котором irqbalance разделяет домены кэша."

msgid "Deepest cache"
msgstr "Кэширование глубокого уровня"

msgid "Enable"
msgstr "Включить"

msgid "Exclude CPUs"
msgstr "Исключить процессоры"

msgid "Exclude IRQs"
msgstr "Исключить IRQ"

msgid "General settings"
msgstr "Основные настройки"

msgid "Grant UCI access for luci-app-irqbalance"
msgstr "Предоставьте доступ к UCI для luci-app-irqbalance"

msgid "Interval"
msgstr "Интервал"

msgid "Invalid"
msgstr "Недопустимый"

msgid ""
"List of CPUs to ignore, can be an integer or integers separated by commas."
msgstr ""
"Список игнорируемых процессоров, может быть целым числом или целыми числами, "
"разделенными запятыми."

msgid "List of IRQs to ignore."
msgstr "Список игнорируемых IRQ."

msgid "Loading..."
msgstr "Загружается…"

msgid "NOT RUNNING"
msgstr "НЕ ЗАПУЩЕНО"

msgid "RUNNING"
msgstr "ЗАПУЩЕНО"

msgid "Show debug output"
msgstr "Показать вывод отладки"

msgid "Show debug output in system log."
msgstr "Показывать отладку в системном журнале."

msgid "Snapshot of current IRQs"
msgstr "Снимок текущих IRQ"

msgid ""
"The purpose of irqbalance is to distribute hardware interrupts across "
"processors/cores on a multiprocessor/multicore system in order to increase "
"performance."
msgstr ""
"Цель irqbalance - распределить аппаратные прерывания между процессорами/"
"ядрами в многопроцессорной/многоядерной системе, чтобы увеличить "
"производительность."

msgid "Valid values: %s."
msgstr "Допустимые значения: %s."

msgid "Value in seconds."
msgstr "Значение в секундах."

msgid "irqbalance"
msgstr "irqbalance"
