msgstr "Syslog 插件设置"

msgid "Syslog enabled"
msgstr "Syslog 已启用"

msgid "System Load"
msgstr "系统负载"

msgid "TCP Connections"
msgstr "TCP 连接数"

msgid "TCPConns Plugin Configuration"
msgstr "TCPConns 插件配置"

msgid "TTL for network packets"
msgstr "网络包 TTL"

msgid "TTL for ping packets"
msgstr "ping 包 TTL"

