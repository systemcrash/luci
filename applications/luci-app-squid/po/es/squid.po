msgstr "Directorio de archivos de Coredump"

msgid "Enable ICMP pinger"
msgstr "Activar pinger ICMP"

msgid "File must be located in directory /etc/squid"
msgstr "El archivo debe estar ubicado en el directorio /etc/squid"

msgid "General Settings"
msgstr "Ajustes generales"

msgid "Grant UCI access for luci-app-squid"
msgstr "Conceder acceso UCI para luci-app-squid"

msgid "HTTP port options"
msgstr "Opciones de puerto HTTP"

msgid "Mime table"
msgstr "Mesa de mímica"

msgid "Port"
msgstr "Puerto"

msgid "SSL DB"
msgstr "Base de datos SSL"

msgid "SSL DB options"
msgstr "Opciones de base de datos SSL"

