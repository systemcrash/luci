msgstr ""
"Ustawienia zaawansowane umożliwiają bezpośredni dostęp do plików "
"konfiguracyjnych."

msgid "Can only be set if Squid is compiled with the %s option"
msgstr "Można ustawiać tylko wtedy, gdy Squid skompilowano z opcją %s"

msgid "Config file"
msgstr "Plik konfiguracyjny"

msgid "Coredump files directory"
msgstr "Katalog plików Coredump"

msgid "Enable ICMP pinger"
msgstr "Włącz pinger ICMP"

msgid "File must be located in directory /etc/squid"
msgstr "Plik musi znajdować się w katalogu /etc/squid"

msgid "General Settings"
msgstr "Ustawienia główne"

msgid "Grant UCI access for luci-app-squid"
msgstr "Przyznaj luci-app-squid dostęp do UCI"

msgid "HTTP port options"
msgstr "Opcje portu HTTP"

msgid "Mime table"
msgstr "Tablica MIME"

msgid "Port"
msgstr "Port"

msgid "SSL DB"
msgstr "Baza danych SSL"

msgid "SSL DB options"
msgstr "Opcje bazy danych SSL"

