msgid "Advanced Settings"
msgstr "Socruithe chun cinn"

msgid "Advanced settings grants you direct access to the configuration files."
msgstr "Tugann ardsocruithe rochtain dhíreach duit ar na comhaid chumraíochta."

msgid "Can only be set if Squid is compiled with the %s option"
msgstr "Ní féidir é a shocrú ach amháin má tá Scuid le chéile leis an rogha %s"

msgid "Config file"
msgstr "Comhad cumraíochta"

msgid "Coredump files directory"
msgstr "Eolaire comhaid coredump"

msgid "Enable ICMP pinger"
msgstr "Cumasaigh pinger ICMP"

msgid "File must be located in directory /etc/squid"
msgstr "Caithfidh an comhad a bheith suite san eolaire /etc/squid"

msgid "General Settings"
msgstr "Socruithe Ginearálta"

msgid "Grant UCI access for luci-app-squid"
msgstr "Deonaigh rochtain UCI do luci-app-squid"

msgid "HTTP port options"
msgstr "Roghanna calafoirt HTTP"

msgid "Mime table"
msgstr "tábla mím"

msgid "Port"
msgstr "Port"

msgid "SSL DB"
msgstr "SSL DB"

msgid "SSL DB options"
msgstr "Roghanna SSL DB"

msgid "Squid"
msgstr "Scuid"

msgid "Visible Hostname"
msgstr "Óstainm Infheicthe"
