msgstr "Theip ar ionchur isteach do IPv4 do pholasaí '%s'"

msgid "Insertion failed for both IPv4 and IPv6 for policy '%s'"
msgstr ""
"Theip ar ionchur isteach do IPv4 agus IPv6 araon le haghaidh beartas '%s'"

