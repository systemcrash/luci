msgid "Add new proxy..."
msgstr ""

msgid "Additional configs"
msgstr "Extra konfigurationer"

msgid "Additional settings"
msgstr "Extra inställningar"

msgid "Admin address"
msgstr "Adress för admin"

msgid "Admin password"
msgstr "Lösenord för admin"

msgid "Admin port"
msgstr "Port för admin"

msgid "Admin user"
msgstr "Admin-användare"

msgid ""
"AdminAddr specifies the address that the admin server binds to.<br />By "
"default, this value is \"0.0.0.0\"."
msgstr ""

msgid ""
"AdminPort specifies the port for the admin server to listen on. If this "
"value is 0, the admin server will not be started.<br />By default, this "
"value is 0."
msgstr ""

msgid ""
"AdminPwd specifies the password that the admin server will use for login."
"<br />By default, this value is \"admin\"."
msgstr ""

msgid ""
"AdminUser specifies the username that the admin server will use for login."
"<br />By default, this value is \"admin\"."
msgstr ""

msgid "Assets dir"
msgstr ""

msgid ""
"AssetsDir specifies the local directory that the admin server will load "
"resources from. If this value is \"\", assets will be loaded from the "
"bundled executable using statik.<br />By default, this value is \"\"."
msgstr ""

msgid "Collecting data ..."
msgstr "Samlar in data ..."

msgid "Common Settings"
msgstr "Vanliga inställningar"

msgid "Compression"
msgstr "Kompression"

msgid "Config files include in temporary config file"
msgstr ""

msgid "Custom domains"
msgstr "Anpassade domäner"

msgid "Disable log color"
msgstr "Inaktivera logg-färg"

msgid ""
"DisableLogColor disables log colors when LogWay == \"console\" when set to "
"true."
msgstr ""

msgid "Encryption"
msgstr "Kryptering"

msgid "Environment variable"
msgstr "Miljövariabel"

msgid "Exit when login fail"
msgstr "Avsluta när inloggningen misslyckas"

msgid "General Settings"
msgstr "Generella inställningar"

msgid "Grant access to LuCI app frpc"
msgstr "Godkänn åtkomst till LuCi-appen frpc"

msgid "HTTP Settings"
msgstr "Inställningar för HTTP"

msgid "HTTP password"
msgstr "Lösenord för HTTP"

msgid "HTTP proxy"
msgstr "Proxy för HTTP"

msgid "HTTP user"
msgstr "Användare för HTTP"

msgid ""
"HeartBeatInterval specifies at what interval heartbeats are sent to the "
"server, in seconds. It is not recommended to change this value.<br />By "
"default, this value is 30."
msgstr ""

msgid ""
"HeartBeatTimeout specifies the maximum allowed heartbeat response delay "
"before the connection is terminated, in seconds. It is not recommended to "
"change this value.<br />By default, this value is 90."
msgstr ""

msgid "Heartbeat interval"
msgstr "Hjärtslagsintervall"

msgid "Heartbeat timeout"
msgstr ""

msgid "Host header rewrite"
msgstr ""

msgid ""
"HttpProxy specifies a proxy address to connect to the server through. If "
"this value is \"\", the server will be connected to directly.<br />By "
"default, this value is read from the \"http_proxy\" environment variable."
msgstr ""

msgid "If remote_port is 0, frps will assign a random port for you"
msgstr ""
"Om remote_port är 0 så kommer frps att tilldela en slumpmässig port till dig"

msgid "Local IP"
msgstr "Lokal IP"

msgid "Local port"
msgstr "Lokal port"

msgid "LocalIp specifies the IP address or host name to proxy to."
msgstr ""

msgid "LocalPort specifies the port to proxy to."
msgstr ""

msgid "Locations"
msgstr "Platser"

msgid "Log file"
msgstr ""

msgid "Log level"
msgstr "Logg-nivå"

msgid "Log max days"
msgstr ""

msgid "Log stderr"
msgstr "Logga stderr"

msgid "Log stdout"
msgstr "Logga stdout"

msgid ""
"LogFile specifies a file where logs will be written to. This value will only "
"be used if LogWay is set appropriately.<br />By default, this value is "
"\"console\"."
msgstr ""

msgid ""
"LogLevel specifies the minimum log level. Valid values are \"trace\", "
"\"debug\", \"info\", \"warn\", and \"error\".<br />By default, this value is "
"\"info\"."
msgstr ""

msgid ""
"LogMaxDays specifies the maximum number of days to store log information "
"before deletion. This is only used if LogWay == \"file\".<br />By default, "
"this value is 0."
msgstr ""

msgid ""
"LoginFailExit controls whether or not the client should exit after a failed "
"login attempt. If false, the client will retry until a login attempt "
"succeeds.<br />By default, this value is true."
msgstr ""

msgid "NOT RUNNING"
msgstr "KÖRS INTE"

msgid ""
"OS environments pass to frp for config file template, see <a href=\"https://"
"github.com/fatedier/frp#configuration-file-template\">frp README</a>"
msgstr ""

msgid "Plugin"
msgstr ""

msgid "Plugin Settings"
msgstr ""

msgid "Protocol"
msgstr "Protokoll"

msgid ""
"Protocol specifies the protocol to use when interacting with the server. "
"Valid values are \"tcp\", \"kcp\", and \"websocket\".<br />By default, this "
"value is \"tcp\"."
msgstr ""

msgid "Proxy Settings"
msgstr "Inställningar för proxy"

msgid "Proxy name"
msgstr ""

msgid "Proxy type"
msgstr "Typ av proxy"

msgid ""
"ProxyType specifies the type of this proxy. Valid values include \"tcp\", "
"\"udp\", \"http\", \"https\", \"stcp\", and \"xtcp\".<br />By default, this "
"value is \"tcp\"."
msgstr ""

msgid "RUNNING"
msgstr "KÖRS"

msgid "Remote port"
msgstr "Fjärrport"

msgid "Respawn when crashed"
msgstr ""

msgid "Role"
msgstr "Roll"

msgid "Run daemon as group"
msgstr "Kör daemon som grupp"

msgid "Run daemon as user"
msgstr "Kör daemon som användare"

msgid "SOCKS5 password"
msgstr ""

msgid "SOCKS5 user"
msgstr ""

msgid "Server address"
msgstr "Server-adress"

msgid "Server name"
msgstr ""

msgid "Server port"
msgstr "Port för server"

msgid ""
"ServerAddr specifies the address of the server to connect to.<br />By "
"default, this value is \"127.0.0.1\"."
msgstr ""

msgid ""
"ServerPort specifies the port to connect to the server on.<br />By default, "
"this value is 7000."
msgstr ""

msgid "Sk"
msgstr "Sk"

msgid "Startup Settings"
msgstr "Inställningar för uppstart"

msgid "Subdomain"
msgstr "Underdomän"

msgid "TCP mux"
msgstr ""

msgid "TLS"
msgstr "TLS"

msgid ""
"TLSEnable specifies whether or not TLS should be used when communicating "
"with the server."
msgstr ""

msgid ""
"TcpMux toggles TCP stream multiplexing. This allows multiple requests from a "
"client to share a single TCP connection. If this value is true, the server "
"must have TCP multiplexing enabled as well.<br />By default, this value is "
"true."
msgstr ""

msgid ""
"This list can be used to specify some additional parameters which have not "
"been included in this LuCI."
msgstr ""

msgid "Token"
msgstr "Tecken"

msgid ""
"Token specifies the authorization token used to create keys to be sent to "
"the server. The server must have a matching token for authorization to "
"succeed. <br />By default, this value is \"\"."
msgstr ""

msgid "Unix domain socket path"
msgstr ""

msgid ""
"UseCompression controls whether or not communication with the server will be "
"compressed.<br />By default, this value is false."
msgstr ""

msgid ""
"UseEncryption controls whether or not communication with the server will be "
"encrypted. Encryption is done using the tokens supplied in the server and "
"client configuration.<br />By default, this value is false."
msgstr ""

msgid "User"
msgstr "Användare"

msgid ""
"User specifies a prefix for proxy names to distinguish them from other "
"clients. If this value is not \"\", proxy names will automatically be "
"changed to \"{user}.{proxy_name}\".<br />By default, this value is \"\"."
msgstr ""

