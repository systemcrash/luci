msgid "%d hour"
msgstr "%d valanda"

msgid "%d minute"
msgstr "%d minutė"

msgid "%d minutes"
msgstr "%d minutės"

msgid "%d second"
msgstr "%d sekundė"

msgid "%d seconds"
msgstr "%d sekundės"

msgid ""
"%s: Name of Physical device which interface went up or down (e.g. \"eth0\" "
"or \"wwan0\")"
msgstr ""
"%s: Šio fizinio įrenginio pavadinimas, kurio sąsają ir/arba sietuvas pakilo "
"arba nusileido (pvz: „eth0“ arba „wwan0“)"

msgid "%s: Name of the action that triggered this event"
msgstr "%s: Šio veiksmo pavadinimas, dėl kurio įvyko šis įvykis"

msgid ""
"%s: Name of the interface which went up or down (e.g. \"wan\" or \"wwan\")"
msgstr ""
"%s: Šio/-s sąsajos ir/arba sietuvo pavadinimas, kuris pakilo arba nusileido "
"(pvz: „wan“ arba „wwan“)"

msgid "* %s: Is called by netifd and mwan3track"
msgstr "* %s: Yra pavadintas pagal „netifd“ ir „mwan3track“"

msgid "* %s: Is only called by mwan3track if tracking has failed"
msgstr "* %s: Yra pavadintas tik pagal „mwan3track“, jeigu sekimas nepavyko"

msgid "* %s: Is only called by mwan3track if tracking was successful"
msgstr ""
"* %s: Yra pavadintas tik pagal „mwan3track“, jeigu sekimas buvo sėkmingas"

msgid "-- Interface Selection --"
msgstr "-- Sąsają ir/arba Sietuvo pasirinkimas --"

msgid "-- Please choose --"
msgstr "-- Prašome pasirinkti --"

msgid ""
"Acceptable values: 1-100. This many Tracking IP addresses must respond for "
"the link to be deemed up"
msgstr ""
"Tinkamos reikšmės: 1-100. Toks kiekis sekiamų IP adresų turi atsakyti, kad "
"sujungimas būtų skaičiuojamas kaip aktyvus"

msgid "Acceptable values: 1-1000. Defaults to 1 if not set"
msgstr "Tinkamos reikšmės: 1-1000. Numatomas į 1, jeigu nenustatytas"

msgid "Acceptable values: 1-256. Defaults to 1 if not set"
msgstr "Tinkamos reikšmės: 1-256. Numatomas į 1, jeigu nenustatytas"

msgid "Alert"
msgstr "Įspėti"

msgid "Also scan this Routing table for connected networks"
msgstr "Tai pat, skenuoti šią kelvados lentelę dėl sujungtų tinklų"

msgid "Check IP rules"
msgstr "Patikrinti IP taisykles"

msgid "Check link quality"
msgstr "Patikrinti sujungimo kokybę"

msgid "Check routing table"
msgstr "Patikrinti kelvados lentelę"

msgid "Collecting data ..."
msgstr "Renkami duomenys..."

msgid "Contents have been saved."
msgstr "Turinys buvo išsaugotas."

msgid "Critical"
msgstr "Kritinė/-is"

msgid "Debug"
msgstr "Derinimas/Trukdžių šalinimas"

msgid "Destination address"
msgstr "Paskirties/Kelionės tikslo adresas"

msgid "Destination port"
msgstr "Paskirties/Kelionės tikslo prievadas"

msgid "Diagnostics"
msgstr "Diagnostika"

msgid "Disabled"
msgstr "Išjungta/Neįgalinta (-s/-i)"

msgid ""
"Downed interface will be deemed up after this many successful ping tests"
msgstr ""
"Neveikianti sąsaja ir/arba sietuvas bus laikoma/-as aktyvia/-iu po nurodytų "
"sėkmingų ryšio atsakų patikrinimų skaičiaus"

msgid "Downtime"
msgstr "Prastovos laikas/trukmė"

msgid "Emergency"
msgstr "Kritinė situacija"

msgid "Enable ssl tracking"
msgstr "Įjungti „SSL“ sekimą"

msgid "Enabled"
msgstr "Įjungta/Įgalinta (-s/-i)"

msgid ""
"Enables firewall rule logging (global mwan3 logging must also be enabled)"
msgstr ""
"Įjungia/Įgalina užkardos žurnalinimo taisyklę (visuotinis „mwan3“ "
"žurnalinimas tai pat, turi būti įjungtas/įgalintas)"

msgid "Enables global firewall logging"
msgstr "Įjungia/Įgalina visuotinį užkardos žurnalinimą"

msgid "Enables https tracking on ssl port 443"
msgstr "Įjungia/Įgalina „HTTPS“ sekimą ant „SSL“ prievado 443"

msgid "Enter value in hex, starting with <code>0x</code>"
msgstr "Įveskite reikšmę šešioliktainiais, pradedant su – „<code>0x</code>“"

msgid "Error"
msgstr "Klaida"

msgid "Execute"
msgstr "Vykdyti/Paleisti"

msgid "Expect interface state on up event"
msgstr "Tikėtis sąsajos/sietuvo būsenos įvykus įvykiui"

msgid "Failure interval"
msgstr "Trikties/Gedimo intervalas"

msgid "Failure latency [ms]"
msgstr "Trikties/Gedimo intervalas [ms]"

msgid "Failure packet loss [%]"
msgstr "Trikties/Gedimo paketo praradimas [%]"

msgid "Firewall loglevel"
msgstr "Užkardos žurnalo lygis"

msgid "Firewall mask"
msgstr "Užkardos tinklavimo „kaukė“ – adresų segregatorius"

msgid "Flush conntrack table"
msgstr "Išvalyti „conntrack“ lentelę"

msgid "Flush global firewall conntrack table on interface events"
msgstr ""
"Išvalyti išorinę/visuotinę užkardos „conntract“ lentelę; sąsajos/sietuvo "
"įvykiuose"

msgid "Globals"
msgstr "Visuotiniai"

msgid "Grant UCI access for luci-app-mwan3"
msgstr "Suteikti „UCI“ prieigą – „luci-app-mwan3“"

msgid "Hotplug ifdown"
msgstr "„Hotplug ifdown“"

msgid "Hotplug ifup"
msgstr "„Hotplug ifup“"

msgid "IPset"
msgstr "„IPset“"

msgid "IPv4"
msgstr "IPv4 – Interneto protokolo versija 4"

msgid "IPv4 and IPv6"
msgstr "IPv4 ir IPv6"

msgid "IPv4 only"
msgstr "Tik IPv4"

msgid "IPv6"
msgstr "IPv6 – Interneto protokolo versija 6"

msgid "IPv6 only"
msgstr "Tik IPv6"

msgid "Info"
msgstr "Informacija"

msgid "Initial state"
msgstr "Pradinė būsena"

msgid "Interface"
msgstr "Sąsaja ir/arba Sietuvas"

msgid "Interface down"
msgstr "Sąsają ir/arba Sietuvas neveikia"

msgid "Interface up"
msgstr "Sąsają ir/arba Sietuvas veikia"

msgid "Interface will be deemed down after this many failed ping tests"
msgstr ""
"Sąsają ir/arba Sietuvas bus skaitomas neveikiančiu, po šių nepavykusių ryšio "
"atsako testų kiekio"

msgid ""
"Interfaces may not share the same name as configured members, policies or "
"rules."
msgstr ""
"Sąsają ir/arba Sietuvas galimai nebendrina tokį pat pavadinimą kaip "
"konfigūruoti nariai, politikos ar taisyklės."

msgid "Internet Protocol"
msgstr "Interneto protokolas"

msgid "Keep failure interval"
msgstr "Laikyti trikčių/gedimų intervalą"

msgid "Keep ping failure interval during failure state"
msgstr "Laikyti ryšio atsako trikčių/gedimų intervalą trikties/gedimo metu"

msgid "Last resort"
msgstr "Paskutinė išeitis"

msgid "Lines beginning with # are comments and are not executed."
msgstr "Eilutės, prasidedančios su – „#“, yra komentarai ir yra nevykdomi."

msgid ""
"Load-balanced member interfaces distribute more traffic out those with "
"higher weights."
msgstr ""
"Įkėlimo/Apkrovos subalansuoti/-os narių sąsajos ir/arba sietuvai paskirsto "
"didesnį srautą tiems, kurių svoris yra didesnis."

msgid "Logging"
msgstr "Žurnalinimas"

msgid "Loglevel"
msgstr "Žurnalo lygis"

msgid "Max TTL"
msgstr "Maksimalus „TTL“"

msgid ""
"May be entered as a single or multiple port(s) (eg \"22\" or \"80,443\") or "
"as a portrange (eg \"1024:2048\") without quotes"
msgstr ""
"Galima įvesti kaip vieną arba kelis prievadus (pvz., „22“ arba „80 443“) "
"arba kaip – prievadų diapazonas (pvz., „1024:2048“) be kabučių"

msgid "Member"
msgstr "Narys"

msgid "Member interfaces with lower metrics are used first."
msgstr ""
"Pirmiausia naudojamos narių sąsajos ir/arba sietuvai su žemesne metrika."

msgid "Member interfaces with the same metric will be load-balanced."
msgstr ""
"Narių sąsajos ir/arba sietuvai su ta pačia metrika bus subalansuoti pagal "
"apkrovą."

msgid "Member used"
msgstr "Naudotas narys"

msgid ""
"Members are profiles attaching a metric and weight to an MWAN interface."
msgstr ""
"Nariai yra profiliai, kurie prie „MWAN“ sąsajos pridedą metriką ir svorį."

msgid ""
"Members may not share the same name as configured interfaces, policies or "
"rules."
msgstr ""
"Nariai negali naudoti to paties pavadinimo kaip sukonfigūruotos sąsajos, "
"sietuvai, politikos ar taisyklės."

msgid "Metric"
msgstr "Metrinė"

msgid "MultiWAN Manager"
msgstr "„MultiWAN“ tvarkytuvas/tvarkytuvė"

msgid "MultiWAN Manager - Diagnostics"
msgstr "„MultiWAN“ tvarkytuvas/tvarkytuvė – Diagnostika"

msgid "MultiWAN Manager - Globals"
msgstr "„MultiWAN“ tvarkytuvas/tvarkytuvė – Visuotiniai"

msgid "MultiWAN Manager - Interfaces"
msgstr "„MultiWAN“ tvarkytuvas/tvarkytuvė – Sąsajos ir/arba Sietuvai"

msgid "MultiWAN Manager - Members"
msgstr "„MultiWAN“ tvarkytuvas/tvarkytuvė – Nariai"

msgid "MultiWAN Manager - Notify"
msgstr "„MultiWAN“ tvarkytuvas/tvarkytuvė – Pranešti"

msgid "MultiWAN Manager - Overview"
msgstr "„MultiWAN“ tvarkytuvas/tvarkytuvė – Peržiūra"

msgid "MultiWAN Manager - Policies"
msgstr "„MultiWAN“ tvarkytuvas/tvarkytuvė – Politika"

msgid "MultiWAN Manager - Rules"
msgstr "„MultiWAN“ tvarkytuvas/tvarkytuvė – Taisyklės"

msgid "MultiWAN Manager - Status"
msgstr "„MultiWAN“ tvarkytuvas/tvarkytuvė – Būklė/Būsena"

msgid "MultiWAN Manager - Troubleshooting"
msgstr "„MultiWAN“ tvarkytuvas/tvarkytuvė – Trikdžių/Gedimų derinimas"

msgid ""
"Mwan3 requires that all interfaces have a unique metric configured in /etc/"
"config/network."
msgstr ""
"„Mwan3“ reikalauja, kad visos/-i sąsajos ir/arba sietuvai turėtų išskirtinę "
"metriką, sukonfigūruotą per – „/etc/config/network“."

msgid "Name length shall not exceed 15 characters"
msgstr "Pavadinimo ilgis neturi viršyti 15-ą rašmenų"

msgid ""
"Name of IPset rule. Requires IPset rule in /etc/dnsmasq.conf (eg \"ipset=/"
"youtube.com/youtube\")"
msgstr ""
"„IPset“ taisyklės pavadinimas. Reikalinga „IPset“ taisyklė – „/etc/dnsmasq."
"conf“ (pvz., „ipset=/youtube.com/youtube“)"

msgid "Names may contain characters A-Z, a-z, 0-9, _ and no spaces-"
msgstr "Varduose gali būti simbolių – „A-Z“, „a-z“, „0-9“, „_“ ir be tarpų-"

msgid "Names may contain characters A-Z, a-z, 0-9, _ and no spaces."
msgstr ""
"Pavadinimuose gali būti simbolių – „A-Z“, „a-z“, „0-9“, „_“ ir be tarpų."

msgid "Names must be 15 characters or less."
msgstr "Pavadinimai turi būti sudaryti iš 15 ar mažiau simbolių."

msgid "Names must match the interface name found in /etc/config/network."
msgstr ""
"Pavadinimai turi sutapti su sąsajos ir/arba sietuvo pavadinimu, kuris "
"randasi – „/etc/config/network“."

msgid "No"
msgstr "Ne"

msgid "No MWAN interfaces found"
msgstr "Nėra „MWAN“ sąsajų ir/arba sietuvų rasta"

msgid "No Tracking"
msgstr "Jokio sekimo"

msgid "No interface metric set!"
msgstr "Nenustatyta sąsajos ir/arba sietuvo metrika!"

msgid "Notes:"
msgstr "Užrašai:"

msgid "Notice"
msgstr "Pranešimas"

msgid "Notify"
msgstr "Pranešti"

msgid "Offline"
msgstr "Neprisijungęs/-usi"

msgid "Online"
msgstr "Prisijungęs/-usi"

msgid "Overview"
msgstr "Apžiūra"

msgid "Ping count"
msgstr "Ryšio atsako skaičiavimas/-ius"

msgid "Ping default gateway"
msgstr "Ryšio atsako numatyta tinklo tarpuvartė"

msgid "Ping interval"
msgstr "Ryšio atsako intervalas"

msgid "Ping interval during failure detection"
msgstr "Ryšio atsako intervalas per trikties gedimo aptikimą"

msgid "Ping interval during failure recovering"
msgstr "Ryšio atsako intervalas per trikties gedimo atsigavimą"

msgid "Ping size"
msgstr "Ryšio atsako dydis"

msgid "Ping timeout"
msgstr "Ryšio atsakas užklausos laikas"

msgid "Ping tracking IP"
msgstr "Ryšio atsako sekimo IP"

msgid ""
"Policies are profiles grouping one or more members controlling how Mwan3 "
"distributes traffic."
msgstr ""
"Politika yra profiliai, grupuojantys vieną ar daugiau narių, "
"kontroliuojančių, kaip – „Mwan3“ paskirsto srautą."

msgid ""
"Policies may not share the same name as configured interfaces, members or "
"rules"
msgstr ""
"Politika negali turėti to paties pavadinimo kaip sukonfigūruotos sąsajos ir/"
"arba sietuvai, nariai ar taisyklės"

msgid "Policy"
msgstr "Politika"

msgid "Policy assigned"
msgstr "Politika priskirta"

msgid "Protocol"
msgstr "Protokolas"

msgid ""
"Put your custom mwan3 action here, they will be executed with each netifd "
"hotplug interface event on interfaces for which mwan3 is enabled."
msgstr ""
"Įdėkite čia savo pasirinktinį – „mwan3“ veiksmą, jie bus vykdomi su "
"kiekvienu – „netifd hotplug“ sąsajų ir/arba sietuvų įvykiu, sąsajose, "
"kuriose yra įjungtas/įgalintas – „mwan3“."

msgid "Recovery interval"
msgstr "Atsigavimo intervalas"

msgid "Recovery latency [ms]"
msgstr "Atsigavimo delsà [ms]"

msgid "Recovery packet loss [%]"
msgstr "Atkūrimo paketo praradimas [%]"

msgid "Routing table %d"
msgstr "Kelvados lentelė „%d“"

msgid "Routing table lookup"
msgstr "Kelvados lentelės „lookup“"

msgid "Rule"
msgstr "Taisyklė"

msgid "Rules are based on IP address, port or protocol."
msgstr "Taisyklės yra pagrįstos IP adresu, prievadu arba protokolu."

msgid "Rules are matched from top to bottom."
msgstr "Taisyklės yra sulyginamos iš viršaus į apačią."

msgid "Rules below a matching rule are ignored."
msgstr "Taisykles, esančios žemiau sulyginamosios taisyklės, yra nepaisomos."

msgid ""
"Rules may not share the same name as configured interfaces, members or "
"policies."
msgstr ""
"Taisyklės negali turėti to paties pavadinimo kaip sukonfigūruotos sąsajos ir/"
"arba sietuvai, nariai ar politika."

msgid "Rules specify which traffic will use a particular MWAN policy."
msgstr "Taisyklės nurodo, kuris srautas naudos tam tikrą – „MWAN“ politiką."

msgid "Seconds. Acceptable values: 1-1000000. Defaults to 600 if not set"
msgstr ""
"Sekundės. Tinkamos reikšmės: 1-1000000. Numatoma į 600-ai, jeigu nenustatyta"

msgid "Source address"
msgstr "Šaltinio adresas"

msgid "Source port"
msgstr "Šaltinio prievadas"

msgid "Status"
msgstr "Būklė/Būsena"

msgid "Sticky"
msgstr "„Sticky“"

msgid "Sticky timeout"
msgstr "„Sticky“ Pasibaigusios užklausos laikas"

msgid "Supports CIDR notation (eg \"192.168.100.0/24\") without quotes"
msgstr "Palaiko „CIDR“ žymėjimą (pvz., „192.168.100.0/24“) be kabučių"

msgid "Task"
msgstr "Užduotis"

msgid "The file is also preserved during sysupgrade."
msgstr "Failas taip pat yra išsaugomas „sysupgrade“ metu."

msgid ""
"The first line of the script must be &#34;#!/bin/sh&#34; without quotes."
msgstr "Pirmoji skripto eilutė turi būti – „&#34;#!/bin/sh&#34;“ be kabučių."

msgid ""
"There are three main environment variables that are passed to this script."
msgstr "Šiam skriptui yra perduodami trys pagrindiniai aplinkos kintamieji."

msgid ""
"This displays the metric assigned to this interface in /etc/config/network"
msgstr ""
"Tai rodo šiai/-am sąsajai ir/arba sietuvui priskirtą metriką – „/etc/config/"
"network“"

msgid "This file is interpreted as a shell script."
msgstr "Šis failas yra interpretuojamas kaip apvalkalo skriptas."

msgid ""
"This hostname or IP address will be pinged to determine if the link is up or "
"down. Leave blank to assume interface is always online"
msgstr ""
"Šis įrenginio (t.y skleidėjo/vedėjo) pavadinimas arba IP adresas bus "
"įjungtas, kad būtų nustatyta, ar nuoroda veikia ar neveikia. Palikite "
"tuščią, kad manytumėte, kad sąsaja ir/arba sietuvas visada yra prisijungusi/-"
"ęs"

msgid "This section allows you to modify the content of \"/etc/mwan3.user\"."
msgstr "Ši sekcija leidžia Jums keisti – „/etc/mwan3.user“ turinį."

msgid "Tracking hostname or IP address"
msgstr ""
"Sekimo/Sekamas įrenginio (t.y skleidėjo/vedėjo) pavadinimas arba IP adresas"

msgid "Tracking method"
msgstr "Sekimo metodas/būdas"

msgid "Tracking reliability"
msgstr "Sekimo patikimumas"

msgid ""
"Traffic destined for known (other than default) networks is handled by the "
"main routing table."
msgstr ""
"Srautas, skirtas žinomiems (išskyrus numatytiesiems) tinklams, tvarkomas "
"pagrindinėje kelvados parinkimo lentelėje."

msgid ""
"Traffic from the same source IP address that previously matched this rule "
"within the sticky timeout period will use the same WAN interface"
msgstr ""
"Srautas iš to paties šaltinio, IP adreso, kuris anksčiau atitiko šią "
"taisyklę – neperžengiant „sticky“ pasibaigusios užklausos laiko laikotarpio "
"ribų; naudos tą pačią „WAN“ sąsają ir/arba sietuvą"

msgid ""
"Traffic matching a rule, but all WAN interfaces for that policy are down "
"will be blackholed."
msgstr ""
"Srautas, atitinkantis taisyklę, bet neveikiančios/neveikiantys visos/-i tos/-"
"ie sąsajos ir/arba sietuvai šiam „WAN“, bus vedami (į) nieką/-ur."

msgid "Traffic not matching any rule is routed using the main routing table."
msgstr ""
"Srautas, neatitinkantis jokios taisyklės, yra maršrutizuotas, naudojant "
"pagrindinę kelvados parinkimo lentelę."

msgid "Troubleshooting"
msgstr "Trikčių/Gedimų derinimas"

msgid "Unable to save contents: %s"
msgstr "Nepavyko išsaugoti turinį: %s"

msgid "Uptime"
msgstr "Aktyvumo laikas"

msgid "View the content of /etc/protocols for protocol description"
msgstr "Peržiūrėti „/etc/protocols“ aprašymo turiniu"

msgid "Warning"
msgstr "Įspėjimas"

msgid ""
"When all policy members are offline use this behavior for matched traffic"
msgstr ""
"Kai visi politikos nariai yra atsijungę, naudokite šią elgseną atitinkamam "
"srautui"

msgid "Yes"
msgstr "Taip"

msgid "blackhole (drop)"
msgstr "juodoji skylė (mesti)"

msgid "connected (mwan3)"
msgstr "prisijungta („mwan3“)"

msgid "default (use main routing table)"
msgstr "Numatytas/-a (naudoti pagrindinį kelvados lentelę)"

msgid "disconnected (mwan3)"
msgstr "atsijungta („mwan3“)"

msgid "ifdown (netifd)"
msgstr "„ifdown“ („netifd“)"

msgid "ifup (netifd)"
msgstr "„ifup“ („netifd“)"

msgid "unreachable (reject)"
msgstr "nepasiekiamas (atmesti)"
