#~ msgid ""
#~ "This section allows you to modify the content of \"/etc/mwan3.user\".<br /"
#~ ">The file is also preserved during sysupgrade.<br /><br />Notes:<br /"
#~ ">This file is interpreted as a shell script.<br />The first line of the "
