msgid "ACL Settings"
msgstr "„ACL“ nustatymai"

msgid "ACL group"
msgstr "„ACL“ grupė"

msgid "Access level"
msgstr "Prieigos lygis"

msgid "Cannot encrypt plaintext password since uhttpd is not installed."
msgstr ""
"Negalima užšifruoti atviro teksto slaptažodžio, nes „uhttpd“ nėra įdiegtas."

msgid "Description"
msgstr "Aprašas/-ymas"

msgid "Grant access to ACL configuration"
msgstr "Duoti prieigą „ACL configuration“"

msgid "Login name"
msgstr "Prisijungimo vardas"

msgid "LuCI Logins"
msgstr "„LuCI“ prisijungimai"

msgid "New account"
msgstr "Nauja paskyra"

msgid "Password value"
msgstr "Slaptažodžio vertė/skaičiaus įvestis"

msgid "Password variant"
msgstr "Slaptažodžio variantas"

msgid "Read access"
msgstr "Perskaitymo prieiga"

msgid "Session timeout"
msgstr "Seanso laikas pasibaigė"

msgctxt "Set all permissions in the table below to one of the given values"
msgid "Set all:"
msgstr "Nustatyti viską:"

msgid ""
"The LuCI ACL management is in an experimental stage! It does not yet work "
"reliably with all applications"
msgstr ""
"„LuCI ACL“ valdymas yra eksperimentiniame etape! Šis neveikia stabiliai su "
"visomis aplikacijomis/programomis"

msgid "The password may not start with \"$p$\"."
msgstr "Slaptažodis negali prasidėti su – „$p$“."

msgid "The system account to use the password from"
msgstr "Sistemos paskyros naudotinas slaptažodis iš"

msgid "UNIX account"
msgstr "„UNIX“ paskyra"

msgid "Unable to encrypt plaintext password: %s"
msgstr "Nepavyko užšifruoti atviro teksto slaptažodžio: %s"

msgid "Use UNIX password in /etc/shadow"
msgstr "Naudoti „UNIX“ slaptažodį randamą: „/etc/shadow“"

msgid "Use encrypted password hash"
msgstr "Naudoti užšifruota slaptažodžio maišą"

msgid "Write access"
msgstr "Rašymo teisė"

msgctxt "No permissions granted"
msgid "denied"
msgstr "neleista"

msgid "does not expire"
msgstr "nepasibaigiantis galiojimas"

msgctxt "All permissions granted"
msgid "full"
msgstr "pilnas"

msgctxt "Select individual permissions manually"
msgid "individual"
msgstr "individualus"

msgctxt "Some permissions granted"
msgid "partial (%d/%d)"
msgstr "dalinis (%d/%d)"

msgctxt "Only read permissions granted"
msgid "readonly"
msgstr "tik skaitymui"
