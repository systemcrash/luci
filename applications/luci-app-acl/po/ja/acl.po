msgid "ACL Settings"
msgstr "ACL 設定"

msgid "ACL group"
msgstr "ACL グループ"

msgid "Access level"
msgstr "アクセスレベル"

msgid "Cannot encrypt plaintext password since uhttpd is not installed."
msgstr ""
"uhttpdがインストールされていないため、プレーンテキストのパスワードを暗号化で"
"きません。"

msgid "Description"
msgstr "説明"

msgid "Grant access to ACL configuration"
msgstr "ACL 構成へのアクセスを許可"

msgid "Login name"
msgstr "ログイン名"

msgid "LuCI Logins"
msgstr "LuCI ログイン"

msgid "New account"
msgstr "新規アカウント"

msgid "Password value"
msgstr "パスワード値"

msgid "Password variant"
msgstr "パスワードヴァリアント"

msgid "Read access"
msgstr "読み取りアクセス"

msgid "Session timeout"
msgstr "セッション・タイムアウト"

msgctxt "Set all permissions in the table below to one of the given values"
msgid "Set all:"
msgstr "すべて設定:"

msgid ""
"The LuCI ACL management is in an experimental stage! It does not yet work "
"reliably with all applications"
msgstr ""
"LuCI ACL管理はまだ実験段階です！すべてのアプリケーションで確実に機能するわけ"
"ではありません"

msgid "The password may not start with \"$p$\"."
msgstr "パスワードは \"$p$\" で始まらない場合があります。"

msgid "The system account to use the password from"
msgstr "パスワードを使用するシステムアカウント"

msgid "UNIX account"
msgstr "UNIX アカウント"

msgid "Unable to encrypt plaintext password: %s"
msgstr "平文パスワードを暗号化できません: %s"

msgid "Use UNIX password in /etc/shadow"
msgstr "/etc/shadow の UNIX パスワードを使用"

msgid "Use encrypted password hash"
msgstr "暗号化されたパスワードハッシュを使用"

msgid "Write access"
msgstr "書き込みアクセス"

msgctxt "No permissions granted"
msgid "denied"
msgstr "拒否"

msgid "does not expire"
msgstr "有効期限なし"

msgctxt "All permissions granted"
msgid "full"
msgstr "すべて"

msgctxt "Select individual permissions manually"
msgid "individual"
msgstr "個別"

msgctxt "Some permissions granted"
msgid "partial (%d/%d)"
msgstr "部分的 (%d/%d)"

msgctxt "Only read permissions granted"
msgid "readonly"
msgstr "読み取り専用"

#~ msgid "Use plain password"
#~ msgstr "平文パスワードを使用"
