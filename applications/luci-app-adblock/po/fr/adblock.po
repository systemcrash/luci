msgstr "Répertoire des bannis"

msgid "Last Run"
msgstr "Dernière exécution"

msgid "Latest DNS Requests"
msgstr "Dernière Requêtes DNS"

msgid "Limit SafeSearch"
msgstr "Limiter SafeSearch"

