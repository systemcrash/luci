msgid "A pair <code>PublicPort;LocalPort</code> e.g. <code>80;8080</code>."
msgstr "<code>公共端口,本地端口</code>对；如<code>80;8080</code>."

msgid ""
"A pair <code>PublicPort;unix:Socket</code> e.g. <code>80;unix:/var/run/nginx."
"sock</code>."
msgstr ""
"<code>公共端口;unix:Socket</code>对；如 <code>80;unix:/var/run/nginx.sock</"
"code>."

msgid ""
"A single <code>Port</code> when the public port is the same as local e.g. "
"<code>80</code>."
msgstr "单一<code>端口</code>当公共端口和本地端口相同时；如<code>80</code>."

msgid "Custom config"
msgstr "自定义配置"

msgid "Description"
msgstr "描述"

msgid "Destination address"
msgstr "目标地址"

msgid "Enabled"
msgstr "已启用"

msgid "For further information <a %s>check the documentation</a>"
msgstr "进一步信息，请<a %s>查阅此文档</a>"

msgid "Grant UCI access for luci-app-tor"
msgstr "授予对 luci-app-tor 的 UCI 权限"

msgid "Hook Script"
msgstr "Hook 脚本"

msgid "Include configs"
msgstr "包含配置"

msgid "Link"
msgstr "链接"

msgid "Onion domain"
msgstr "洋葱域名"

msgid "Path to script which is executed after starting Tor."
msgstr "启动 Tor 之后执行的脚本所在的路径。"

msgid "Public ports to local"
msgstr "将端口公开给本地"

msgid ""
"The .onion domain is passed into the script via parameter <code>--update-"
"onion HOSTNAME</code>."
msgstr ""
".onion 洋葱域名通过参数 <code>--update-onion HOSTNAME</code>传递进脚本。"

msgid ""
"Tor Onion (Hidden) Services are proxy tunnels to your local website, SSH and "
"other services."
msgstr "Tor Onion (Hidden) 服务是到本地网站、SSH 和其他服务的代理隧道。"

msgid "Tor Onion Services"
msgstr "Tor Onion 服务"

msgid "Tor Onion router"
msgstr "Tor Onion 路由"

msgid "Tor onion router"
msgstr "Tor onion 路由"

msgid "Traffic will be forwarded to the target hostname"
msgstr "流量将被转发到目标主机名"
