msgid "A pair <code>PublicPort;LocalPort</code> e.g. <code>80;8080</code>."
msgstr ""
"Una coppia <code>PublicPort;LocalPort</code> ad es. <code>80;8080</code>."

msgid ""
"A pair <code>PublicPort;unix:Socket</code> e.g. <code>80;unix:/var/run/nginx."
"sock</code>."
msgstr ""
"Una coppia <code>PublicPort;unix:Socket</code> per esempio <code>80;unix:/"
"var/run/nginx.sock</code>."

msgid ""
"A single <code>Port</code> when the public port is the same as local e.g. "
"<code>80</code>."
msgstr ""
"Una singola <code>Porta</code> quando la porta pubblica è la stessa della "
"locale, ad esempio <code>80</code>."

msgid "Custom config"
msgstr "Configurazione personalizzata"

msgid "Description"
msgstr "Descrizione"

msgid "Destination address"
msgstr "Indirizzo di destinazione"

msgid "Enabled"
msgstr "Abilita"

msgid "For further information <a %s>check the documentation</a>"
msgstr "Per ulteriori informazioni <a %$>verifica la documentazione</a>"

msgid "Grant UCI access for luci-app-tor"
msgstr "Concedi l'accesso UCI per l'app LuCI luci-app-tor"

msgid "Hook Script"
msgstr "Hook Script"

msgid "Include configs"
msgstr "Include le configurazioni"

msgid "Link"
msgstr "Link"

msgid "Onion domain"
msgstr "Dominio Onion"

msgid "Path to script which is executed after starting Tor."
msgstr "Percorso dello script eseguito dopo l'avvio di Tor."

msgid "Public ports to local"
msgstr "Porte pubbliche a locali"

msgid ""
"The .onion domain is passed into the script via parameter <code>--update-"
"onion HOSTNAME</code>."
msgstr ""
"Il dominio .onion viene passato nello script tramite parametro <code>--"
"update-onion HOSTNAME</code>."

msgid ""
"Tor Onion (Hidden) Services are proxy tunnels to your local website, SSH and "
"other services."
msgstr ""
"I servizi Onion (nascosti) di Tor sono tunnel proxy verso il tuo sito web "
"locale, SSH e altri servizi."

msgid "Tor Onion Services"
msgstr "Servizi Tor Onion"

msgid "Tor Onion router"
msgstr "Router Tor Onion"

msgid "Tor onion router"
msgstr "Tor onion router"

msgid "Traffic will be forwarded to the target hostname"
msgstr "Il traffico sarà inoltrato all'hostname di destinazione"
