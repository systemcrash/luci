msgid "A pair <code>PublicPort;LocalPort</code> e.g. <code>80;8080</code>."
msgstr "Para <code>PortPubliczny;PortLokalny</code> np. <code>80;8080</code>."

msgid ""
"A pair <code>PublicPort;unix:Socket</code> e.g. <code>80;unix:/var/run/nginx."
"sock</code>."
msgstr ""
"Para <code>PortPubliczny;unix:Gniazdo</code> np. <code>80;unix:/var/run/"
"nginx.sock</code>."

msgid ""
"A single <code>Port</code> when the public port is the same as local e.g. "
"<code>80</code>."
msgstr ""
"Pojedynczy <code>Port</code>, gdy port publiczny jest taki sam jak port "
"lokalny, np. <code>80</code>."

msgid "Custom config"
msgstr "Konfiguracja niestandardowa"

msgid "Description"
msgstr "Opis"

msgid "Destination address"
msgstr "Adres przeznaczenia"

msgid "Enabled"
msgstr "Włączone"

msgid "For further information <a %s>check the documentation</a>"
msgstr "Aby uzyskać więcej informacji, <a %s>sprawdź dokumentację</a>"

msgid "Grant UCI access for luci-app-tor"
msgstr "Przyznaj luci-app-tor dostęp do UCI"

msgid "Hook Script"
msgstr "Skrypt hakowy"

msgid "Include configs"
msgstr "Dołącz konfiguracje"

msgid "Link"
msgstr "Łącze"

msgid "Onion domain"
msgstr "Domena onion"

msgid "Path to script which is executed after starting Tor."
msgstr "Ścieżka do skryptu, który jest wykonywany po uruchomieniu sieci Tor."

msgid "Public ports to local"
msgstr "Porty publiczne na lokalne"

msgid ""
"The .onion domain is passed into the script via parameter <code>--update-"
"onion HOSTNAME</code>."
msgstr ""
"Domena .onion jest przekazywana do skryptu poprzez parametr <code>--update-"
"onion NAZWAHOSTA</code>."

msgid ""
"Tor Onion (Hidden) Services are proxy tunnels to your local website, SSH and "
"other services."
msgstr ""
"Usługi onion Tor (ukryte) to tunele proxy do Twojej lokalnej witryny "
"internetowej, SSH i innych usług."

msgid "Tor Onion Services"
msgstr "Usługi onion Tor"

msgid "Tor Onion router"
msgstr "Router onion Tor"

msgid "Tor onion router"
msgstr "Router onion Tor"

msgid "Traffic will be forwarded to the target hostname"
msgstr "Ruch będzie przekazywany do docelowej nazwy hosta"
