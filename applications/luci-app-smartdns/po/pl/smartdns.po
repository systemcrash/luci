msgstr "Serwer TCP"

msgid "TCP port is empty"
msgstr "Port TCP jest pusty"

msgid "TLS Hostname Verify"
msgstr "Weryfikacja nazwy hosta TLS"

msgid "TLS SNI name"
msgstr "Nazwa SNI TLS"

msgid "TLS SPKI Pinning"
msgstr "Przypinanie SPKI TLS"

msgid "TTL for all domain result."
msgstr "TTL dla wyniku w całej domenie."

msgid "Technical Support"
msgstr "Pomoc techniczna"

msgid "URL"
msgstr "Adres URL"

msgid "URL format error, format: http:// or https://"
msgstr "Błąd formatu adresu URL, format: http:// lub https://"

