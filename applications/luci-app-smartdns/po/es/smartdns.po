msgid "Skip Ipset Rule"
msgstr "Omitir regla de Ipset"

msgid "Skip Nameserver Rule"
msgstr "Omitir regla de servidor de nombres"

msgid "Skip SOA Address Rule"
msgstr "Omitir regla de dirección SOA"

