msgstr "Имя SNI TLS"

msgid "TLS SPKI Pinning"
msgstr "Закрепление TLS SPKI"

msgid "TTL for all domain result."
msgstr "TTL для всех результатов работы домена."

msgid "Technical Support"
msgstr "Техническая поддержка"

