msgstr "समता"

msgid "Protocol"
msgstr "प्रोटोकॉल"

msgid "Proxies"
msgstr "प्रॉक्सी"

msgid "RX LED configuration"
msgstr "आरएक्स एलईडी कॉन्फिगरेशन"

msgid "Raw"
msgstr "कच्चा"

msgid "Rawlp"
msgstr "रॉल्प"

msgid "Service port"
msgstr "सेवा पोर्ट"

msgid "Settings"
msgstr "सेटिंग्ज"

msgid "State"
msgstr "स्थिती"

msgid "Stop bits"
msgstr "स्टॉप बिट"

