msgid "Extra options"
msgstr "अतिरिक्त पर्याय"

msgid "Global switch"
msgstr "ग्लोबल स्विच"

msgid "Grant access to LuCI app ser2net"
msgstr "LuCI अ‍ॅप ser2net ला प्रवेश मंजूर करा"

msgid "Ignore modem control signals"
msgstr "मॉडेम कंट्रोल सिग्नलकडे दुर्लक्ष करा"

msgid "LED redirect"
msgstr "LED पुनर्निर्देशित"

msgid "LEDs"
msgstr "एलईडी"

msgid "None"
msgstr "एकही नाही"

msgid "Odd"
