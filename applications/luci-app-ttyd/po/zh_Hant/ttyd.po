msgid "Accept only one client and exit on disconnection"
msgstr "僅接受一個客戶端，並在切斷時退出"

msgid "Add instance"
msgstr "加入實體"

msgid "Allow URL args"
msgstr "容許 URL 引數"

msgid ""
"Allow client to send command line arguments in URL (eg: http://"
"localhost:7681?arg=foo&arg=bar)"
msgstr ""
"容許客戶端在 URL 中發送命令行引數（例如：http://localhost:7681?"
"arg=foo&arg=bar）"

msgid "Bind to UNIX domain socket instead of IP port"
msgstr "綁定到 UNIX 套接字而不是 IP 連接埠"

msgid "Check origin"
msgstr "檢查原點"

msgid "Client option"
msgstr "客戶端選項"

msgid "Command"
msgstr "命令"

msgid "Config"
msgstr "設定"

msgid "Credential"
msgstr "憑證"

msgid "Credential for Basic Authentication"
msgstr "基本認證憑證"

msgid "Custom index.html path"
msgstr "自訂 index.html 路徑"

msgid "Debug"
msgstr "除錯"

msgid "Do not allow clients to write to the TTY"
msgstr "不容許客戶端寫入 TTY"

msgid "Do not allow websocket connection from different origin"
msgstr "不容許來自不同原點的 WebSocket 連線"

msgid "Enable"
msgstr "啟用"

msgid "Enable IPv6 support"
msgstr "啟用 IPv6 支援"

msgid "Enable SSL"
msgstr "啟用 SSL"

msgid "Error"
msgstr "錯誤"

msgid "Grant UCI access for luci-app-ttyd"
msgstr "授予 luci-app-ttyd 擁有 UCI 存取的權限"

msgid "Group ID"
msgstr "群組 ID"

msgid "Group id to run with"
msgstr "要運行的群組 ID"

msgid "IPv6"
msgstr "IPv6"

msgid "Index"
msgstr "索引頁"

msgid "Info"
msgstr "資訊"

msgid "Interface"
msgstr "介面"

msgid "Make sure to set up another authorization method."
msgstr "確保設定另一種授權方法。"

msgid "Max clients"
msgstr "最大客戶數"

msgid "Maximum clients to support (default: 0, no limit)"
msgstr "最大支援客戶端數（預設值「0」表示不限制）"

msgid "Network interface to bind (eg: eth0)"
msgstr "要綁定的網路介面（例如：eth0）"

msgid "Note that reverse proxied pages is NOT protected by password like LuCI."
msgstr "請注意，反向代理頁面不像 LuCI 那樣受密碼保護。"

msgid "Notice"
msgstr "注意"

msgid "Once"
msgstr "一次"

msgid "Override URL in Terminal tab. For use with reverse proxy."
msgstr "覆寫「終端」標籤中的 URL。與反向代理一起使用。"

msgid "Port"
msgstr "連接埠"

msgid "Port to listen (default: 7681, use `0` for random port)"
msgstr "監聽埠（預設值：7681，「0」表示隨機埠）"

msgid ""
"Random ttyd port (port=0) is not supported.<br />Change to a fixed port and "
"try again."
msgstr "不支援 ttyd 隨機埠（埠號為 0）；<br />變更為固定埠後重試。"

msgid "Read-only"
msgstr "唯讀"

msgid "SSL"
msgstr "SSL"

msgid "SSL CA file path for client certificate verification"
msgstr "用於客戶端憑證驗證的 SSL CA 檔案路徑"

msgid "SSL ca"
msgstr "SSL CA"

msgid "SSL cert"
msgstr "SSL 憑證"

msgid "SSL certificate file path"
msgstr "SSL 憑證檔案路徑"

msgid "SSL key"
msgstr "SSL 金鑰"

msgid "SSL key file path"
msgstr "SSL 金鑰檔案路徑"

msgid "Send option to client"
msgstr "將選項發送到客戶端"

msgid "Set log level (default: 7)"
msgstr "設定日誌等級（預設值：7）"

msgid "Signal"
msgstr "訊號"

msgid "Signal to send to the command when exit it (default: 1, SIGHUP)"
msgstr "退出時發送到命令的訊號（預設值：1－SIGHUP）"

msgid "Terminal"
msgstr "終端"

msgid "Terminal type"
msgstr "終端類型"

msgid "Terminal type to report (default: xterm-256color)"
msgstr "報告終端類型（預設值：xterm-256color）"

msgid "UNIX domain socket path (eg: /var/run/ttyd.sock)"
msgstr "UNIX 套接字路徑（例如：/var/run/ttyd.sock）"

msgid "UNIX socket"
msgstr "UNIX套接字"

msgid "UNIX socket path"
msgstr "UNIX套接字路徑"

msgid "URL override"
msgstr "網址覆寫"

msgid "User ID"
msgstr "使用者 ID"

msgid "User id to run with"
msgstr "要運行的使用者 ID"

msgid "Warning"
msgstr "警告"

msgid "ttyd Instance"
msgstr "ttyd 實例"

