msgid "Accept only one client and exit on disconnection"
msgstr "仅接受一个客户端并在断开连接后退出"

msgid "Add instance"
msgstr "添加实例"

msgid "Allow URL args"
msgstr "允许 URL 参数"

msgid ""
"Allow client to send command line arguments in URL (eg: http://"
"localhost:7681?arg=foo&arg=bar)"
msgstr ""
"允许客户端在 URL 中传递命令行参数 (如: http://localhost:7681?arg=foo&arg=bar)"

msgid "Bind to UNIX domain socket instead of IP port"
msgstr "绑定到 UNIX 域套接字而不是 IP 端口"

msgid "Check origin"
msgstr "检查来源"

msgid "Client option"
msgstr "客户端选项"

msgid "Command"
msgstr "命令"

msgid "Config"
msgstr "配置"

msgid "Credential"
msgstr "凭据"

msgid "Credential for Basic Authentication"
msgstr "用于基本身份验证的凭据"

msgid "Custom index.html path"
msgstr "自定义 index.html 路径"

msgid "Debug"
msgstr "调试"

msgid "Do not allow clients to write to the TTY"
msgstr "不允许客户端写入 TTY"

msgid "Do not allow websocket connection from different origin"
msgstr "不允许不同来源的 websocket 连接"

msgid "Enable"
msgstr "启用"

msgid "Enable IPv6 support"
msgstr "启用 IPv6 支持"

msgid "Enable SSL"
msgstr "启用 SSL"

msgid "Error"
msgstr "错误"

msgid "Grant UCI access for luci-app-ttyd"
msgstr "授予UCI访问luci-app-ttyd的权限"

msgid "Group ID"
msgstr "组 ID"

msgid "Group id to run with"
msgstr "要运行的组 ID"

msgid "IPv6"
msgstr "IPv6"

msgid "Index"
msgstr "首页"

msgid "Info"
msgstr "信息"

msgid "Interface"
msgstr "接口"

msgid "Make sure to set up another authorization method."
msgstr "确保设置另一种授权方式。"

msgid "Max clients"
msgstr "最大客户端数量"

msgid "Maximum clients to support (default: 0, no limit)"
msgstr "最大支持的客户端数量（默认：0，无限制）"

msgid "Network interface to bind (eg: eth0)"
msgstr "要绑定的网络接口（如：eth0）"

msgid "Note that reverse proxied pages is NOT protected by password like LuCI."
msgstr "注意，通过反向代理的页面不会像LuCI那样受到密码保护。"

msgid "Notice"
msgstr "注意"

msgid "Once"
msgstr "一次"

msgid "Override URL in Terminal tab. For use with reverse proxy."
msgstr "在“终端”标签页中绕过 URL。用于反向代理。"

msgid "Port"
msgstr "端口"

msgid "Port to listen (default: 7681, use `0` for random port)"
msgstr "要监听的端口 (默认: 7681, `0` 代表随机端口)"

msgid ""
"Random ttyd port (port=0) is not supported.<br />Change to a fixed port and "
"try again."
msgstr "不支持随机 ttyd 端口 (端口=0)。<br />改为固定端口然后再试一次。"

msgid "Read-only"
msgstr "只读"

msgid "SSL"
msgstr "SSL"

msgid "SSL CA file path for client certificate verification"
msgstr "用于客户端证书验证的 SSL CA 文件路径"

msgid "SSL ca"
msgstr "SSL ca"

msgid "SSL cert"
msgstr "SSL 证书"

msgid "SSL certificate file path"
msgstr "SSL 证书文件路径"

msgid "SSL key"
msgstr "SSL 密钥"

msgid "SSL key file path"
msgstr "SSL 密钥文件路径"

msgid "Send option to client"
msgstr "发送选项到客户端"

msgid "Set log level (default: 7)"
msgstr "设置日志级别 (默认: 7)"

msgid "Signal"
msgstr "信号"

msgid "Signal to send to the command when exit it (default: 1, SIGHUP)"
msgstr "退出时要发送给命令的信号 (默认: 1, SIGHUP)"

msgid "Terminal"
msgstr "终端"

msgid "Terminal type"
msgstr "终端类型"

msgid "Terminal type to report (default: xterm-256color)"
msgstr "要报告的终端类型 (默认: xterm-256color)"

msgid "UNIX domain socket path (eg: /var/run/ttyd.sock)"
msgstr "UNIX 域套接字路径（如：/var/run/ttyd.sock）"

msgid "UNIX socket"
msgstr "UNIX 域套接字"

msgid "UNIX socket path"
msgstr "UNIX 域套接字路径"

msgid "URL override"
msgstr "URL 重写"

msgid "User ID"
msgstr "用户 ID"

msgid "User id to run with"
msgstr "要运行的用户 ID"

msgid "Warning"
msgstr "警告"

msgid "ttyd Instance"
msgstr "ttyd 实例"

