msgstr ""
"Intervalo vienetas, skirtas priverstiniams naujinimams siųsti – „DDNS“ "
"teikėjui."

msgid "Interval unit to check for changed IP"
msgstr "Intervalo vienetas, norint patikrinti dėl pakeisto IP"

msgid "Last Update"
msgstr "Paskutinis atnaujinimas"

