msgstr "Žurnalo failo žiūrovas/-ė"

msgid "Log directory"
msgstr "Žurnalo katalogas"

msgid "Log length"
msgstr "Žurnalo ilgis"

msgid "Log to file"
msgstr "Žurnalinti į failą"

msgid "Log to syslog"
msgstr "Žurnalinti į „syslog“"

