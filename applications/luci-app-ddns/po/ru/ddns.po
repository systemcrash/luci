msgstr "Новая служба DDNS…"

msgid "Next Update"
msgstr "Следующее обновление"

msgid "No Data"
msgstr "Нет данных"

msgid "No certificates found"
msgstr "Сертификаты не найдены"

msgid "No logging"
msgstr "Отключить журналирование"

